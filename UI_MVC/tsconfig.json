{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "lib": ["es2022", "dom"],  
    "esModuleInterop": true,
    "outDir": "wwwroot/dist/js",
    "rootDir": "wwwroot/js",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["wwwroot/js/**/*.ts"],
  "exclude": ["node_modules"]
}
