@page
@model CitizenPanel.UI.MVC.Areas.Identity.Pages.Account.LoginModel

@{
ViewData["Title"] = "Aanmelden";
}
@section Styles {
    <link rel="stylesheet" href="~/dist/clientapp/assets/styles.css" asp-append-version="true"/>
}

<div class="login-page-wrapper">
    <div class="login-card-container">
        <h1 class="login-title">@ViewData["Title"]</h1>

        <h2 class="login-subtitle">Selecteer een methode om mee in te loggen</h2>
        <div class="login-type-selector">
            <button type="button" id="accountBtn" class="login-type-button"
                    data-type="Account">Aanmelden met account
            </button>
            <button type="button" id="codeBtn" class="login-type-button"
                    data-type="Code">Aanmelden met code
            </button>
        </div>
        <input type="hidden" id="selectedLogin" value="@(TempData["SelectedLoginType"] ?? "Account")"/>
        <hr class="login-divider"/>

        <div class="login-form-fields-container">
            <div id="accountFields" class="login-form-panel @(TempData["SelectedLoginType"]?.ToString() == "Code" ? "form-hidden" : "active")">
                <form id="login" method="post">
                    <div asp-validation-summary="ModelOnly" class="login-validation-summary" role="alert"></div>
                    <div class="mb-4">
                        <label asp-for="Input.Email" class="login-form-label">Email</label>
                        <input asp-for="Input.Email" class="login-input-field" autocomplete="username" aria-required="true"
                               placeholder="name@example.com"/>
                        <span asp-validation-for="Input.Email"
                              class="login-validation-message @(TempData["SelectedLoginType"]?.ToString() == "Code" ? "form-hidden" : "")"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Input.Password" class="login-form-label">Wachtwoord</label>
                        <input asp-for="Input.Password" class="login-input-field" autocomplete="current-password"
                               aria-required="true" placeholder="password"/>
                        <span asp-validation-for="Input.Password"
                              class="login-validation-message @(TempData["SelectedLoginType"]?.ToString() == "Code" ? "form-hidden" : "")"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Input.RememberMe" class="login-checkbox-label">
                            <input asp-for="Input.RememberMe"/>
                            <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
                        </label>
                    </div>
                    <div>
                        <button id="login-submit" type="submit" class="login-submit-button">Aanmelden</button>
                    </div>
                    <div class="login-links-section">
                        <p>
                            <a id="forgot-password" asp-page="./ForgotPassword">Wachtwoord vergeten?</a>
                        </p>
                        <p>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Registreer als nieuwe
                                organisatie</a>
                        </p>
                        <p>
                            <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Verzend bevestigingsmail
                                opnieuw</a>
                        </p>
                    </div>
                    <input type="hidden" name="Input.LoginType" value="Account"/>
                </form>
            </div>

            <div id="codeFields" class="login-form-panel @(TempData["SelectedLoginType"]?.ToString() == "Code" ? "active" : "form-hidden")">
                <form id="codeForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="login-validation-summary" role="alert"></div>
                    <div class="mb-4">
                        <label asp-for="Input.Code" class="login-form-label">Code</label>
                        <input asp-for="Input.Code" class="login-input-field" aria-required="true" placeholder="Code">
                        <span asp-validation-for="Input.Code"
                              class="login-validation-message @(TempData["SelectedLoginType"]?.ToString() == "Account" ? "form-hidden" : "")"></span>
                    </div>
                    <input type="hidden" name="Input.LoginType" value="Code"/>
                    <button id="codeSubmit" type="submit" class="login-submit-button">Aanmelden</button>
                    <div class="login-links-section">
                        <p>
                            <a asp-controller="MemberRegister" asp-action="Index">Code nog niet geregistreerd?</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script type="module" src="~/dist/clientapp/assets/index.js"></script>
}
