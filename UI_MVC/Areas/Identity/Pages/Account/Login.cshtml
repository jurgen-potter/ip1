@page
@model LoginModel

@{
    ViewData["Title"] = "Aanmelden";
}

<h1>@ViewData["Title"]</h1>
<div class="row">
    <div class="col-md-4">
        <section>
            <h2>Selecteer een methode om mee in te loggen</h2>
            <div class="btn-group w-100">
                <button type="button" id="accountBtn" class="btn btn-lg btn-outline-primary login-type-btn"
                        data-type="Account">Aanmelden met account
                </button>
                <button type="button" id="codeBtn" class="btn btn-lg btn-outline-primary login-type-btn"
                        data-type="Code">Aanmelden met code
                </button>
            </div>
            <input type="hidden" id="selectedLogin" value="@(TempData["SelectedLoginType"] ?? "Account")"/>
            <hr/>

            <div id="accountFields">
                <form id="login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true"
                               placeholder="name@example.com"/>
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <span asp-validation-for="Input.Email"
                              class="text-danger @(TempData["SelectedLoginType"]?.ToString() == "Code" ? "d-none" : "")"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password"
                               aria-required="true" placeholder="password"/>
                        <label asp-for="Input.Password" class="form-label">Wachtwoord</label>
                        <span asp-validation-for="Input.Password"
                              class="text-danger @(TempData["SelectedLoginType"]?.ToString() == "Code" ? "d-none" : "")"></span>
                    </div>
                    <div class="checkbox mb-3">
                        <label asp-for="Input.RememberMe" class="form-label">
                            <input class="form-check-input" asp-for="Input.RememberMe"/>
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>
                    <div>
                        <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Aanmelden</button>
                    </div>
                    <div>
                        <p>
                            <a id="forgot-password" asp-page="./ForgotPassword">Wachtwoord vergeten?</a>
                        </p>
                        <p>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Registreer als nieuwe
                                organisatie</a>
                        </p>
                        <p>
                            <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Verzend bevestigingsmail
                                opnieuw</a>
                        </p>
                    </div>
                    <input type="hidden" name="Input.LoginType" value="Account"/>
                </form>
            </div>

            <div id="codeFields">
                <form id="codeForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Code" class="form-control" aria-required="true" placeholder="Code">
                        <label asp-for="Input.Code">Code</label>
                        <span asp-validation-for="Input.Code"
                              class="text-danger @(TempData["SelectedLoginType"]?.ToString() == "Account" ? "d-none" : "")"></span>
                    </div>
                    <input type="hidden" name="Input.LoginType" value="Code"/>
                    <button id="codeSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Aanmelden</button>
                    <div>
                        <p>
                            <a asp-controller="MemberRegister" asp-action="Index">Code nog niet geregistreerd?</a>
                        </p>
                    </div>
                </form>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    <script defer src="~/dist/js/account/login.js">
    </script>
}
