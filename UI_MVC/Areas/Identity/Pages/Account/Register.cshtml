@page
@model CitizenPanel.UI.MVC.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Registratie";
}

<div class="flex justify-center items-center min-h-[70vh]">
    <div class="w-full max-w-md bg-white rounded-xl shadow-lg p-8">
        <h1 class="text-2xl font-bold mb-6 text-center">@ViewData["Title"]</h1>
        
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <input type="hidden" asp-for="@Model.IsStaff" />
            <h2 class="text-xl font-semibold mb-4 text-center">Registreer uw organisatie.</h2>
            <hr class="my-4 border-gray-200"/>
            <div asp-validation-summary="ModelOnly" class="text-red-500" role="alert"></div>
            <div class="mb-4">
                <label asp-for="Input.Email" class="block text-sm font-medium mb-1">Email</label>
                <input asp-for="Input.Email" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" autocomplete="username" aria-required="true" placeholder="name@example.com"/>
                <span asp-validation-for="Input.Email" class="text-red-500 text-sm"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Input.Password" class="block text-sm font-medium mb-1">Wachtwoord</label>
                <input asp-for="Input.Password" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" autocomplete="new-password" aria-required="true" placeholder="password"/>
                <span asp-validation-for="Input.Password" class="text-red-500 text-sm"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium mb-1">Bevestig wachtwoord</label>
                <input asp-for="Input.ConfirmPassword" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" autocomplete="new-password" aria-required="true" placeholder="password"/>
                <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-sm"></span>
            </div>
            <button id="registerSubmit" type="submit" class="w-full bg-primary hover:bg-primary-hover text-white px-4 py-2 rounded-lg transition-colors duration-150">Registreer</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
