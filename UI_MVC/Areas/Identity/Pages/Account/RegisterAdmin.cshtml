@page
@using CitizenPanel.BL.Domain.Users
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model CitizenPanel.UI.MVC.Areas.Identity.Pages.Account.RegisterAdminModel
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Registratie van admin";
    var user = await UserManager.GetUserAsync(User);
    var isSuper = user?.IsSuper == true;
}
@section Styles {
    <link rel="stylesheet" href="~/dist/clientapp/assets/styles.css" asp-append-version="true"/>
}

<div class="auth-page-wrapper">
    <div class="auth-card-container">
        <h1 class="auth-page-title">@ViewData["Title"]</h1>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <h2 class="auth-form-title">Registreer het nieuwe admin account.</h2>
            <hr class="auth-divider"/>
            <div asp-validation-summary="ModelOnly" class="auth-validation-summary" role="alert"></div>

            <div class="auth-form-group">
                <label asp-for="Input.Email" class="auth-form-label">Email</label>
                <input asp-for="Input.Email" class="auth-input-field" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="auth-validation-message"></span>
            </div>

            <div class="auth-form-group">
                <label asp-for="Input.Password" class="auth-form-label">Wachtwoord</label>
                <input asp-for="Input.Password" class="auth-input-field" autocomplete="new-password" aria-required="true" placeholder="Wachtwoord" />
                <span asp-validation-for="Input.Password" class="auth-validation-message"></span>
            </div>

            <div class="auth-form-group">
                <label asp-for="Input.ConfirmPassword" class="auth-form-label">Bevestig wachtwoord</label>
                <input asp-for="Input.ConfirmPassword" class="auth-input-field" autocomplete="new-password" aria-required="true" placeholder="Wachtwoord" />
                <span asp-validation-for="Input.ConfirmPassword" class="auth-validation-message"></span>
            </div>

            @if (isSuper)
            {
                <div class="auth-form-group">
                    <label asp-for="Input.IsSuper" class="auth-form-label">Maak superadmin</label>
                    <input asp-for="Input.IsSuper" class="auth-input-field" type="checkbox" aria-required="false" />
                    <span asp-validation-for="Input.IsSuper" class="auth-validation-message"></span>
                </div>
            }

            <button id="registerSubmit" type="submit" class="auth-submit-button">Registreer</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
