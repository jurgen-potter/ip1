@model CitizenPanel.UI.MVC.Models.QuestionnaireModules.QuestionnaireResponseViewModel

@{
    ViewBag.Title = Model.Questionnaire.Title + " - Resultaat";
}
@section Styles {
    <link rel="stylesheet" href="~/dist/clientapp/assets/styles.css" asp-append-version="true"/>
}

<div class="questionnaire-result-container"> 
    <h2 class="questionnaire-result-main-title">Advies op basis van uw antwoorden</h2>

    @if (Model.Questionnaire.Questions.Any(q => q.IsDetail))
    {
        <div class="questionnaire-result-card">
            <h5 class="questionnaire-result-card-title">Details van uw panel</h5>
            @foreach (var question in Model.Questionnaire.Questions.Where(q => q.IsDetail).OrderBy(q => q.Position))
            {
                int selectedAnswerId;
                if (!Model.Answers.TryGetValue(question.Id, out selectedAnswerId))
                {
                    continue; 
                }

                var selectedAnswer = question.Answers.FirstOrDefault(a => a.Id == selectedAnswerId);
                if (selectedAnswer == null)
                {
                    continue;
                }

                <div class="questionnaire-result-item">
                    <span class="questionnaire-result-label">Vraag:</span>
                    <p class="questionnaire-result-text">@question.Description</p>
                    
                    <span class="questionnaire-result-label mt-2">Uw antwoord:</span>
                    <p class="questionnaire-result-text">@selectedAnswer.Description</p>
                    
                    @if (!string.IsNullOrWhiteSpace(selectedAnswer.Advice))
                    {
                        <span class="questionnaire-result-label mt-2">Aanbeveling:</span>
                        <p class="questionnaire-result-text">@selectedAnswer.Advice</p>
                    }
                </div>
            }
        </div>
    }

    @foreach (var question in Model.Questionnaire.Questions.Where(q => !q.IsDetail).OrderBy(q => q.Position))
    {
        int selectedAnswerId;
        if (!Model.Answers.TryGetValue(question.Id, out selectedAnswerId))
        {
            continue; 
        }

        var selectedAnswer = question.Answers.FirstOrDefault(a => a.Id == selectedAnswerId);
        if (selectedAnswer == null)
        {
            continue;
        }

        if (!Model.IsCritical || selectedAnswer.IsCritical)
        {
            <div class="questionnaire-result-card">
                <h5 class="questionnaire-result-card-title">@question.Description</h5>
                
                <span class="questionnaire-result-label">Uw antwoord:</span>
                <p class="questionnaire-result-text">@selectedAnswer.Description</p>

                @if (!string.IsNullOrWhiteSpace(selectedAnswer.Advice))
                {
                    <span class="questionnaire-result-label mt-2">Aanbeveling:</span>
                    <p class="questionnaire-result-text">@selectedAnswer.Advice</p>
                }
            </div>
        }
    }
    <div class="questionnaire-result-actions">
        <a href="@Url.Action("Index", "Questionnaire", new { questionnaireId = @Model.QuestionnaireId })" class="btn btn-outline-secondary">
            <i class="fas fa-redo-alt"></i> Nieuwe berekening
        </a>
    </div>
</div>
