@model CitizenPanel.UI.MVC.Models.QuestionnaireModules.QuestionnaireResponseViewModel

@{
    ViewBag.Title = @Model.Questionnaire.Title;
}

<div class="my-4"> 
    <h2 class="mb-4 text-2xl font-bold">Advies op basis van uw antwoorden</h2>
    @if (Model.Questionnaire.Questions.Any(q => q.IsDetail))
    {
        <div class="bg-white rounded-lg shadow-md overflow-hidden my-2 p-2">
            <div class="p-4">
                <h5 class="text-xl font-bold mb-3">Details van uw panel</h5>
                @foreach (var question in Model.Questionnaire.Questions.Where(q => q.IsDetail).OrderBy(q => q.Position))
                {
                    int selectedAnswerId;
                    if (!Model.Answers.TryGetValue(question.Id, out selectedAnswerId))
                    {
                        continue; // No answer submitted for this question
                    }

                    var selectedAnswer = question.Answers.FirstOrDefault(a => a.Id == selectedAnswerId);
                    if (selectedAnswer == null)
                    {
                        continue;
                    }

                    <h7 class="mb-1 block"><strong>Vraag: </strong>@question.Description</h7>
                    <p class="mb-2"><strong>Uw antwoord:</strong> @selectedAnswer.Description</p>
                    @if (!string.IsNullOrWhiteSpace(selectedAnswer.Advice))
                    {
                        <p><strong>Aanbeveling:</strong> @selectedAnswer.Advice</p>
                    }
                }
            </div>
        </div>
    }

    @foreach (var question in Model.Questionnaire.Questions.Where(q => !q.IsDetail).OrderBy(q => q.Position))
    {
        int selectedAnswerId;
        if (!Model.Answers.TryGetValue(question.Id, out selectedAnswerId))
        {
            continue; // No answer submitted for this question
        }

        var selectedAnswer = question.Answers.FirstOrDefault(a => a.Id == selectedAnswerId);
        if (selectedAnswer == null)
        {
            continue;
        }

        if (!Model.IsCritical || selectedAnswer.IsCritical)
        {
            <div class="bg-white rounded-lg shadow-md overflow-hidden my-2 p-2">
                <div class="p-4">
                    <h5 class="text-xl font-bold mb-3">@question.Description</h5>
                    <p class="mb-2"><strong>Uw antwoord:</strong> @selectedAnswer.Description</p>

                    @if (!string.IsNullOrWhiteSpace(selectedAnswer.Advice))
                    {
                        <p><strong>Aanbeveling:</strong> @selectedAnswer.Advice</p>
                    }
                </div>
            </div>
        }
    }
    <a href="@Url.Action("Index", "Questionnaire", new { questionnaireId = @Model.QuestionnaireId })" class="mt-4 inline-block px-4 py-2 border border-secondary text-secondary hover:bg-secondary hover:text-white rounded-lg transition-colors duration-150">Nieuwe berekening</a>
</div>