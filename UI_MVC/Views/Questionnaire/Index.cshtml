@model QuestionnaireResponseViewModel

@{
    ViewBag.Title = @Model.Questionnaire.Title;
}

<div class="container my-4">
    <h2 class="mb-4">Is een panel voor u?</h2>

    <form asp-action="Result" method="post">
        <input type="hidden" name="questionnaireId" value="@Model.QuestionnaireId"/>
        @foreach (var question in Model.Questionnaire.Questions)
        {
            <div class="card mb-4">
                <div class="card-header"><strong>Vraag @question.Position</strong></div>
                <div class="card-body">
                    <p class="mb-3">@question.Description</p>
                    @foreach (var answer in question.Answers.OrderBy(a => a.Position))
                    {
                        var isChecked = Model.SelectedAnswerIds.Contains(answer.Id);
                        <div class="form-check mb-2">
                            <input
                                class="form-check-input"
                                type="radio"
                                name="Answers[@question.Id]"
                                value="@answer.Id"
                                id="@($"q{question.Id}_a{answer.Id}")"
                                @(isChecked ? "checked" : "")
                                required />

                            <label
                                class="form-check-label"
                                for="@($"q{question.Id}_a{answer.Id}")">
                                @answer.Description
                            </label>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="d-flex justify-content-start mt-4 gap-2">
            <button type="submit" class="btn btn-success mt-3">Verzenden</button>
            @if (User.IsInRole("Organization"))
            {
                <button
                    type="submit"
                    formaction="@Url.Action("Save")"
                    formnovalidate
                    class="btn btn-success">
                    Opslaan
                </button>
            }
        </div>
    </form>
</div>