@using System.Security.Claims
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<CitizenPanel.BL.Domain.Panels.Meeting>

@{
    ViewData["Title"] = "Aanbevelingen Overzicht";
}
@section Styles {
    <link rel="stylesheet" href="~/dist/clientapp/assets/index.css" asp-append-version="true"/>
}

<div class="recommendations-page-container">
    <h1 class="recommendations-page-main-title">Aanbevelingen</h1>
    <div id="current-user-id" data-user-id="@User.FindFirstValue(ClaimTypes.NameIdentifier)" style="display: none;"></div>

    @if (Model != null && Model.Any(m => m.Recommendations.Any()))
    {
        @foreach (var meeting in Model.Where(m => m.Recommendations.Any()).OrderBy(m => m.Date))
        { 
            <div class="recommendation-meeting-group">
                <h2 class="recommendation-meeting-title">@meeting.Title (@meeting.Date.ToString("dd MMMM yyyy"))</h2> 
                <div class="recommendations-list-grid">
                    @foreach (var recommendation in meeting.Recommendations)
                    {
                        <div class="recommendation-card">
                            <div class="recommendation-card-body">
                                <h5 class="recommendation-card-title">
                                    @recommendation.Title
                                    @if (recommendation.IsAnonymous)
                                    {
                                        <span class="anonymous-label">(Anonieme stemming)</span>
                                    }
                                </h5>
                                <p class="recommendation-card-text">@recommendation.Description</p>
                                
                                <p class="recommendation-card-status @(!recommendation.IsVotable ? "ended" : (recommendation.UserVotes.Count() >= recommendation.NeededVotes && User.IsInRole("Organization") ? "balanced" : ""))"
                                   id="@($"statusText{recommendation.Id}")">
                                <p class="mb-1" id="@($"hiddenText{recommendation.Id}")" hidden>
                                    @if (!recommendation.IsVotable)
                                    {
                                        <strong>Het stemmen is afgelopen</strong>
                                    }
                                    else if (recommendation.UserVotes.Count() >= recommendation.NeededVotes && User.IsInRole("Organization"))
                                    {
                                        <strong>U heeft genoeg stemmen voor een gebalanceerd resultaat</strong>
                                    }
                                </p>

                                @if (User.IsInRole("Organization"))
                                {
                                    <div class="recommendation-card-vote-info">
                                        <p class="mb-1">Alle stemmen: <span id="vote-count-@recommendation.Id">@recommendation.Votes</span></p>
                                        <ul>
                                            <li>
                                                <p class="vote-count-for">Voor: <span>@recommendation.UserVotes.Count(uv => uv.Recommended)</span></p>
                                            </li>
                                            <li>
                                                <p class="vote-count-against">Tegen: <span>@recommendation.UserVotes.Count(uv => !uv.Recommended)</span></p>
                                            </li>
                                        </ul>
                                    </div>
                                    <div class="recommendation-card-actions">
                                        @if (!recommendation.IsAnonymous)
                                        {
                                            <button type="button" class="btn btn-outline-info btn-show-voters"
                                                    data-modal-trigger="votersModal" 
                                                    data-recommendation-id="@recommendation.Id"
                                                    data-recommendation-title="@recommendation.Title">
                                                Bekijk Stemmers
                                            </button>
                                        }
                                        @if (recommendation.IsVotable)
                                        {
                                            <button type="button" class="btn btn-outline-danger btn-stop-voting"
                                                    data-modal-trigger="confirmationModal" 
                                                    data-recommendation-id="@recommendation.Id">
                                                Stop stemronde
                                            </button>
                                        }
                                    </div>
                                }
                                @if (!User.IsInRole("Organization") && recommendation.IsVotable)
                                {
                                    <div class="recommendation-vote-forms">
                                        <form class="vote-form"> 
                                            <input type="hidden" name="id" value="@recommendation.Id"/>
                                            <button type="submit" name="voteAction" value="for" class="btn btn-success vote-button">Stem voor</button>
                                        </form>
                                        <form class="vote-form">
                                            <input type="hidden" name="id" value="@recommendation.Id"/>
                                            <button type="submit" name="voteAction" value="against" class="btn btn-danger vote-button">Stem tegen</button>
                                        </form>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-10">
            <p class="text-xl text-gray-500">Er zijn momenteel geen aanbevelingen beschikbaar.</p>
        </div>
    }
</div>


<div id="votersModal" class="custom-modal-overlay" aria-labelledby="votersModalLabel" role="dialog" aria-modal="true">
    <div class="custom-modal-dialog modal-lg"> 
        <div class="custom-modal-header">
            <h5 class="custom-modal-title" id="votersModalLabel">Stemmers voor Aanbeveling</h5>
            <button type="button" class="custom-modal-close-button" data-modal-close="votersModal" aria-label="Close">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>
        <div class="custom-modal-body" id="votersModalBody">
            <p class="text-gray-500">Laden...</p> 
        </div>
        <div class="custom-modal-footer">
            <button type="button" class="btn btn-secondary" data-modal-close="votersModal">Sluiten</button>
        </div>
    </div>
</div>

<div id="confirmationModal" class="custom-modal-overlay" aria-labelledby="confirmationModalLabel" role="dialog" aria-modal="true">
    <div class="custom-modal-dialog modal-sm">
        <div class="custom-modal-header">
            <h5 class="custom-modal-title" id="confirmationModalLabel">Bevestiging</h5>
             <button type="button" class="custom-modal-close-button" data-modal-close="confirmationModal" aria-label="Close">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>
        <div class="custom-modal-body">
            <p>Weet u zeker dat u het stemmen wilt stoppen?</p>
        </div>
        <div class="custom-modal-footer">
            <button type="button" id="cancelStopVotingBtn" class="btn btn-success" data-modal-close="confirmationModal">Even wachten</button>
            <button type="button" class="btn btn-danger" id="confirmStopVotingBtn">Stop de stemming</button> 
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/dist/clientapp/assets/index.js" asp-append-version="true"></script>
}
