@model IEnumerable<CitizenPanel.BL.Domain.Panel.Recommendation>

@{
    ViewData["Title"] = "Recommendations";
}

<h1>Aanbevelingen</h1>

<div class="row">
    @foreach (var recommendation in Model)
    {
        <div class="col-md-4">
            <div class="card" style="margin-bottom: 20px;">
                @* <img src="img moet hier" class="card-img-top" alt="..."> *@
                <div class="card-body">
                    <h5 class="card-title">@recommendation.Title</h5>
                    <p class="card-text">@recommendation.Description</p>
                    <p>Aantal stemmen: <span id="vote-count-@recommendation.Id">@recommendation.Votes</span></p>
                    <form class="vote-form">
                        <input type="hidden" name="id" value="@recommendation.Id" />
                        <button type="submit" class="btn btn-primary">Stem</button>
                    </form>
                </div>
            </div>
        </div>
    }

</div>

<a asp-action="AddRecommendation" asp-controller="Recommendation" class="btn btn-success">Add Recommendation</a>

@section Scripts {
    <script defer src="js/recommendation/vote.js">
</script>
}
