@using System.Security.Claims
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<CitizenPanel.BL.Domain.Panels.Meeting>

@{
    ViewData["Title"] = "Recommendations";
}

<h1>Aanbevelingen</h1>
<div id="current-user-id" data-user-id="@User.FindFirstValue(ClaimTypes.NameIdentifier)" style="display: none;"></div>
@foreach (var meeting in Model.Where(m => m.Recommendations.Count() != 0).OrderBy(m => m.Date))
{ 
    <h2>@meeting.Title</h2> 
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var recommendation in meeting.Recommendations)
    {
        <div class="col d-flex">
            <div class="card h-100 w-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">
                        @if (recommendation.IsAnonymous)
                        {
                            @($"(Anonieme stemming) ")
                        }
                        @recommendation.Title
                    </h5>
                    <p class="card-text flex-grow-1">@recommendation.Description</p>
                    <p class="mb-1" id="@($"hiddenText{recommendation.Id}")" hidden>
                        <strong>Het stemmen is afgelopen</strong>
                    </p>

                    @if (!recommendation.IsVotable)
                    {
                        <p class="mb-1"><strong>Het stemmen is afgelopen</strong></p>
                    }
                    else if (recommendation.UserVotes.Count() >= recommendation.NeededVotes && User.IsInRole("Organization"))
                    {
                        <p class="mb-1" id="@($"toHideText{recommendation.Id}")"><strong>U heeft genoeg stemmen voor een gebalanceerd resultaat</strong></p>
                    }

                    @if (User.IsInRole("Organization"))
                    {
                        <div class="mt-auto">
                            <p class="mb-1">Alle stemmen: <span id="vote-count-@recommendation.Id">@recommendation.Votes</span></p>
                            <ul>
                                <li>
                                    <p class="mb-1" style="color: limegreen">Voor deze aanbeveling: <span id="vote-count-@recommendation.Id">@recommendation.UserVotes.Count(uv => uv.Recommended)</span></p>
                                </li>
                                <li>
                                    <p class="mb-1" style="color: red">Tegen deze aanbeveling: <span id="vote-count-@recommendation.Id">@recommendation.UserVotes.Count(uv => !uv.Recommended)</span></p>
                                </li>
                            </ul>
                            <div class="d-flex justify-content-start mt-4 gap-2">
                                @if (!recommendation.IsAnonymous)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-info btn-show-voters"
                                            data-recommendation-id="@recommendation.Id"
                                            data-recommendation-title="@recommendation.Title">
                                        Bekijk Stemmers
                                    </button>
                                }
                                @if (recommendation.IsVotable)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger btn-stop-voting"
                                            data-recommendation-id="@recommendation.Id">
                                        Stop stemronde
                                    </button>
                                }
                            </div>
                        </div>
                    }
                    @if (!User.IsInRole("Organization") && recommendation.IsVotable)
                    {
                        <div id="vote-form">
                            <form class="mt-auto">
                                <input type="hidden" name="id" value="@recommendation.Id"/>
                                <button type="submit" id="vote-for" class="btn btn-success">Stem voor</button>
                            </form>

                            <form class="mt-auto">
                                <input type="hidden" name="id" value="@recommendation.Id"/>
                                <button type="submit" id="vote-against" class="btn btn-danger">Stem tegen</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
}


<div id="votersModal" class="member-reg-modal-overlay hidden" aria-labelledby="votersModalLabel" aria-hidden="true">
    <div class="member-reg-modal-dialog modal-dialog-scrollable">
        <div class="member-reg-modal-header">
            <h5 class="member-reg-modal-title" id="votersModalLabel">Stemmers voor Aanbeveling</h5>
        </div>
        <div class="member-reg-modal-body" id="votersModalBody">
            Laden...
        </div>
        <div class="member-reg-modal-footer">
            <button type="button" class="member-reg-modal-button-confirm" id="closeModal">Sluiten</button>
        </div>
    </div>
</div>

<div id="confirmationModal" class="member-reg-modal-overlay hidden" aria-labelledby="confirmationModalLabel" aria-hidden="true">
    <div class="member-reg-modal-dialog">
        <div class="member-reg-modal-header">
            <h5 class="member-reg-modal-title" id="confirmationModalLabel">Bevestiging</h5>
        </div>
        <div class="member-reg-modal-body">
            <p>Weet u zeker dat het stemmen wilt stoppen?</p>
        </div>
        <div class="member-reg-modal-footer">
            <button type="button" class="member-reg-modal-button-confirm" id="stopVotingBtn">Stop de stemming</button>
            <button type="button" class="member-reg-modal-button-cancel" id="cancel-stop-voting">Even wachten</button>
        </div>
    </div>
</div>


@section Scripts {
    <script type="module" src="~/dist/clientapp/assets/endVote.js"></script>
    <script type="module" src="~/dist/clientapp/assets/vote.js"></script>
    <!---<script type="module" src="~/dist/clientapp/assets/votersModalLoader.js"></script>
}