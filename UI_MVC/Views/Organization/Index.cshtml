@using CitizenPanel.BL.Domain.Users
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.TagHelpers
@inject UserManager<ApplicationUser> UserManager

@{
    ViewBag.Title = "Organisatie overzicht";
    var user = await UserManager.GetUserAsync(User);
    var isSuper = user?.IsSuper == true;
    
}
@section Styles {
    <link rel="stylesheet" href="~/dist/clientapp/assets/styles.css" asp-append-version="true"/>
}

<div class="auth-page-wrapper py-12"> 
    <div class="auth-card-container"> 
        <h2 class="auth-page-title">@ViewBag.Title</h2> 
        
        <div class="overview-actions-list">
            <a asp-controller="Panel" asp-action="UserPanel" class="btn btn-primary">
                Panel(s) bekijken
            </a>
            <a asp-controller="Recruitment" asp-action="Index" class="btn btn-primary">
                Panel aanmaken
            </a>
            @if (isSuper)
            {
                <a asp-page="/Account/Register" asp-area="Identity" asp-route-staff="true" class="btn btn-primary">
                    Voeg nieuwe organisatiebeheerder toe
                </a>
                <a asp-action="ManageOrganization" class="btn btn-primary">
                    Organisatiebeheer
                </a>
            }
        </div>
    </div>
</div>