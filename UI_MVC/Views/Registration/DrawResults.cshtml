@model CitizenPanel.BL.Domain.Draws.DrawResult
@using CitizenPanel.BL.Domain.Draws
@using CitizenPanel.BL.Domain.Users;
@using Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Lotingsresultaten";
    var panelId = ViewBag.PanelId;
    var panelName = ViewBag.PanelName;
    var drawStatus = (DrawStatus)ViewBag.DrawStatus;
}

<h2>Lotingsresultaten voor panel: @panelName</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Lotingsstatus</h5>
            </div>
            <div class="card-body">
                <p>
                    Status:
                    <span class="badge bg-success">Loting afgerond</span>
                </p>
                <a asp-action="Index" asp-route-panelId="@panelId" class="btn btn-secondary">
                    Terug naar overzicht
                </a>
            </div>
        </div>
    </div>
</div>

@foreach (var group in new[]
          {
              new { Title = "Geselecteerde deelnemers", Members = Model.SelectedMembers },
              new { Title = "Reserve deelnemers", Members = Model.ReserveMembers },
          })
{
    <div class="row mt-4">
        <div class="col-md-12">
            <h3>@group.Title</h3>
            <table class="table table-striped">
                <thead>
                <tr>
                    <th>Naam</th>
                    <th>Geslacht</th>
                    <th>Leeftijd</th>
                    <th>Categorie</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var member in group.Members)
                {
                    var mp = member.MemberProfile;
                    if (mp == null)
                    {
                        continue;
                    }

                    var nameDisplay = string.IsNullOrEmpty(mp.FirstName) ? "[Geen naam]" : mp.FirstName;

                    var genderDisplay = mp.Gender == Gender.Male ? "Man" : "Vrouw";

                    string ageGroup;
                    if (mp.Age <= 0) 
                    {
                        ageGroup = "[Onbekend]"; 
                    }
                    else if (mp.Age >= 18 && mp.Age <= 25)
                    {
                        ageGroup = "18-25";
                    }
                    else if (mp.Age <= 40)
                    {
                        ageGroup = "26-40";
                    }
                    else if (mp.Age <= 60)
                    {
                        ageGroup = "41-60";
                    }
                    else
                    {
                        ageGroup = "60+";
                    }

                    var criteriaList = new List<string> { genderDisplay, ageGroup };
                    if (mp.SelectedCriteria != null)
                    {
                        criteriaList.AddRange(mp.SelectedCriteria.Where(sc => sc != null && !string.IsNullOrEmpty(sc.Name)).Select(sc => sc.Name));
                    }

                    var categoryDisplay = string.Join(" × ", criteriaList);

                    <tr>
                        <td>@nameDisplay</td>
                        <td>@genderDisplay</td>
                        <td>@mp.Age</td>
                        <td>@categoryDisplay</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

@if (!Model.SelectedMembers.Any() && !Model.ReserveMembers.Any())
{
    <div class="alert alert-warning">
        Er zijn geen resultaten beschikbaar. De loting moet mogelijk opnieuw worden uitgevoerd.
    </div>
}