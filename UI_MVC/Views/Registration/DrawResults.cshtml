@model CitizenPanel.BL.Domain.Draws.DrawResult
@using CitizenPanel.BL.Domain.Draws
@using CitizenPanel.BL.Domain.Users;
@using Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Lotingsresultaten";
    var panelId = ViewBag.PanelId;
    var panelName = ViewBag.PanelName;
    var drawStatus = (DrawStatus)ViewBag.DrawStatus;
    
    var criteriaNamesLookup = ViewBag.CriteriaNames as Dictionary<int, string> ?? new Dictionary<int, string>();

}

<h2>Lotingsresultaten voor panel: @panelName</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Lotingsstatus</h5>
            </div>
            <div class="card-body">
                <p>
                    Status:
                    <span class="badge bg-success">Loting afgerond</span>
                </p>
                <a asp-action="Index" asp-route-panelId="@panelId" class="btn btn-secondary">
                    Terug naar overzicht
                </a>
            </div>
        </div>
    </div>
</div>

@* --- GEWIJZIGD: Loop over SelectedInvitations en ReserveInvitations --- *@
@foreach (var group in new[]
          {
              new { Title = "Geselecteerde deelnemers", Invitations = Model.SelectedInvitations },
              new { Title = "Reserve deelnemers", Invitations = Model.ReserveInvitations },
          })
{
    @if (group.Invitations.Any())
    {
        <div class="row mt-4">
            <div class="col-md-12">
                <h3>@group.Title</h3>
                <table class="table table-striped">
                    <thead>
                    <tr>
                        <th>Naam</th>
                        <th>Geslacht</th>
                        <th>Leeftijd</th>
                        <th>Categorie</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var invitation in group.Invitations)
                    {
                        var identifierDisplay = !string.IsNullOrEmpty(invitation.Email) ? invitation.Email : invitation.Code ?? "[Onbekend]";
                        var genderDisplay = invitation.Gender == Gender.Male ? "Man" : invitation.Gender == Gender.Female ? "Vrouw" : "[Onbekend]";
                        var townDisplay = !string.IsNullOrEmpty(invitation.Town) ? invitation.Town : "[Onbekend]";

                        string ageGroupDisplay;
                        if (invitation.Age <= 0)
                        {
                            ageGroupDisplay = "[Onbekende leeftijd]";
                        }
                        else if (invitation.Age >= 18 && invitation.Age <= 25)
                        {
                            ageGroupDisplay = "18-25";
                        }
                        else if (invitation.Age <= 40)
                        {
                            ageGroupDisplay = "26-40";
                        }
                        else if (invitation.Age <= 60)
                        {
                            ageGroupDisplay = "41-60";
                        }
                        else
                        {
                            ageGroupDisplay = "60+";
                        }


                        // Criteria ophalen via lookup
                        var criteriaDisplayList = new List<string> { genderDisplay, ageGroupDisplay }; // Start met basis demo info
                        if (invitation.SelectedCriteria != null)
                        {
                            foreach (var criteriaId in invitation.SelectedCriteria)
                            {
                                if (criteriaNamesLookup.TryGetValue(criteriaId, out var name))
                                {
                                    criteriaDisplayList.Add(name);
                                }
                            }
                        }

                        // Verwijder dubbele items (bv. als gender/leeftijd ook als los criterium is opgeslagen)
                        var distinctCriteria = criteriaDisplayList.Distinct(StringComparer.OrdinalIgnoreCase).ToList();
                        var categoryDisplay = string.Join(" × ", distinctCriteria);

                        <tr>
                            <td>@identifierDisplay</td>
                            <td>@genderDisplay</td>
                            <td>@invitation.Age</td>
                            <td>@townDisplay</td>
                            <td>@categoryDisplay</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
}


    @if (!Model.SelectedInvitations.Any() && !Model.ReserveInvitations.Any())
    {
        <div class="alert alert-warning">
            Er zijn geen resultaten beschikbaar. De loting moet mogelijk opnieuw worden uitgevoerd.
        </div>
    }
