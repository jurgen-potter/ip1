@model CitizenPanel.BL.Domain.Draws.DrawResult
@using CitizenPanel.BL.Domain.Users
@using Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Lotingsresultaten";
    var panelId = ViewBag.PanelId;
    var panelName = ViewBag.PanelName;
    var criteriaNamesLookup = ViewBag.CriteriaNames as Dictionary<int, string> ?? new Dictionary<int, string>();
}
@section Styles {
    <link rel="stylesheet" href="~/dist/clientapp/assets/styles.css" asp-append-version="true"/>
}

<div class="reg-overview-container">
    <h2 class="reg-overview-title">Lotingsresultaten voor panel: @panelName</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="reg-overview-alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="reg-overview-grid">
        <div class="reg-overview-card">
            <div class="reg-overview-card-header">
                <h5>Lotingsstatus</h5>
            </div>
            <div class="reg-overview-card-body">
                <p>
                    Status:
                    <span class="reg-overview-status-badge status-success">Loting afgerond</span>
                </p>
                <a asp-action="Index" asp-controller="Registration" asp-route-panelId="@panelId" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Terug naar registratie-overzicht
                </a>
            </div>
        </div>
    </div>

    @foreach (var group in new[]
              {
                  new { Title = "Geselecteerde deelnemers", Invitations = Model.SelectedInvitations }
              })
    {
        @if (group.Invitations.Any()) 
        {
            <div class="draw-results-section">
                <h3 class="draw-results-group-title">@group.Title</h3>
                <div class="overflow-x-auto bg-white rounded-lg shadow">
                    <table class="reg-overview-table table-striped">
                        <thead>
                        <tr>
                            <th>Email</th>
                            <th>Categorie</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var invitation in group.Invitations)
                        {
                            var identifierDisplay = !string.IsNullOrEmpty(invitation.Email) ? invitation.Email : invitation.Code ?? "[Onbekend]";
                            var genderDisplay = invitation.Gender == Gender.Male ? "Man" : invitation.Gender == Gender.Female ? "Vrouw" : "[Onbekend]";
                            var townDisplay = !string.IsNullOrEmpty(invitation.Town) ? invitation.Town : "[Onbekend]";

                            string ageGroupDisplay;
                            if (invitation.Age <= 0) { ageGroupDisplay = "[Onbekende leeftijd]"; }
                            else if (invitation.Age >= 18 && invitation.Age <= 25) { ageGroupDisplay = "18-25"; }
                            else if (invitation.Age <= 40) { ageGroupDisplay = "26-40"; } 
                            else if (invitation.Age <= 60) { ageGroupDisplay = "41-60"; } 
                            else { ageGroupDisplay = "60+"; }   

                            var criteriaDisplayList = new List<string> { genderDisplay, ageGroupDisplay }; 
                            if (invitation.SelectedCriteria != null)
                            {
                                foreach (var criteriaId in invitation.SelectedCriteria)
                                {
                                    if (criteriaNamesLookup.TryGetValue(criteriaId, out var name))
                                    {
                                        criteriaDisplayList.Add(name);
                                    }
                                }
                            }
                            
                            var distinctCriteria = criteriaDisplayList.Distinct(StringComparer.OrdinalIgnoreCase).ToList();
                            var categoryDisplay = string.Join(" × ", distinctCriteria);

                            <tr>
                                <td>@identifierDisplay</td>
                                <td>@categoryDisplay</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }

    @if (!Model.SelectedInvitations.Any()) 
    {
        <div class="reg-overview-alert alert-warning">
            Er zijn geen resultaten beschikbaar voor geselecteerden. De loting moet mogelijk opnieuw worden uitgevoerd of er waren geen aanmeldingen.
        </div>
    }
</div>
