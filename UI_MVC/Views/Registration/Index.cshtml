@using CitizenPanel.BL.Domain.Draw
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model ResultViewModel
@{
    ViewData["Title"] = "Registratie-overzicht";
    var panelId = ViewBag.PanelId ?? 1;
    var drawStatus = ViewBag.DrawStatus != null ? (DrawStatus)ViewBag.DrawStatus : DrawStatus.FirstPhaseActive;
    var hasSufficientRegistrations = ViewBag.HasSufficientRegistrations ?? false;
}

<h2>Registratie-overzicht voor panel @panelId</h2>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Lotingsstatus</h5>
            </div>
            <div class="card-body">
                <p>
                    Status:
                    <span class="badge @(drawStatus == DrawStatus.FirstPhaseActive ? "bg-primary" : drawStatus == DrawStatus.Complete ? "bg-success" : "bg-secondary")">
                        @(drawStatus == DrawStatus.FirstPhaseActive ? "Eerste fase actief" : "Loting afgerond")
                    </span>
                </p>
                @if (drawStatus == DrawStatus.Complete)
                {
                <a asp-action="DrawResults" asp-route-panelId="@panelId" class="btn btn-info">
                    Bekijk lotingsresultaten
                </a>
                }

                @if (drawStatus == DrawStatus.FirstPhaseActive)
                {
                    <form asp-action="EditMail" asp-route-panelId="@panelId" method="post" id="StartFinalPhaseForm">
                        <button type="button" class="btn btn-primary" id="startSecondPhaseBtn">
                            Start finale loting
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

@if (ViewBag.TotalMembers != null)
{
    <div class="alert alert-info">
        <h5>Debug Informatie</h5>
        <p>Totaal aantal members: @ViewBag.TotalMembers</p>
        
        @if (ViewBag.MemberDetails != null && ViewBag.MemberDetails.Count > 0)
        {
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Gender</th>
                        <th>Age</th>
                        <th>Town</th>
                        <th>Selected Criteria</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in ViewBag.MemberDetails)
                    {
                        <tr>
                            <td>@member.Id</td>
                            <td>@member.Gender</td>
                            <td>@member.Age</td>
                            <td>@member.Town</td>
                            <td>@member.SelectedCriteria</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

<h3>Overzicht aanmeldingen per doelgroep</h3>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Criteria</th>
        <th>Aantal Registraties</th>
        <th>Status</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var bucket in Model.Buckets)
    {
        <tr>
            <td>
                @(string.Join(" × ", bucket.SubCriteriaNames.Select((sub,i) => $"{sub} ({bucket.CriteriaNames[i]})")))
            </td>
            <td>@bucket.RegisteredCount/@bucket.Count</td>
            <td>
                @if (bucket.IsSufficient)
                {
                    <span class="badge bg-success">Voldoende</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Onvoldoende</span>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmationModal" tabindex="-1" aria-labelledby="confirmationModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmationModalLabel">Bevestiging</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="confirmationModalBody">
                <p>Weet u zeker dat u de finale lotingsfase wilt starten?</p>
                <div id="insufficientWarning" style="display: none;" class="alert alert-warning">
                    <strong>Let op:</strong> Er zijn nog onvoldoende aanmeldingen bij sommige criteria. Het is aan te raden om meer deelnemers te werven voordat u doorgaat.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuleren</button>
                <button type="button" class="btn btn-primary" id="confirmStartFinalPhase">Bevestigen</button>
            </div>
        </div>
    </div>
</div>

<div id="hasSufficientRegistrations" type="hidden" data-value="@hasSufficientRegistrations"></div>

@section Scripts {
    <script defer src="@Url.Content("~/dist/js/registration/index.js")"></script>
}