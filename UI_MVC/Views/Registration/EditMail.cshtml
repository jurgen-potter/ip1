@using Microsoft.AspNetCore.Mvc.TagHelpers
@model CitizenPanel.UI.MVC.Models.Draws.FinalDrawViewModel

@{
    ViewBag.Title = "Bewerk bericht naar deelnemers";
}
@section Styles {
    <link rel="stylesheet" href="~/dist/clientapp/assets/styles.css" asp-append-version="true"/>
}

<div class="auth-page-wrapper">
    <div class="message-edit-form-container">
        <h2 class="message-edit-form-title">@ViewBag.Title</h2>

        <form asp-action="StartFinalDrawPhase" asp-route-panelId="@Model.PanelId" method="post">
            <input type="hidden" asp-for="PanelId" />
            <div asp-validation-summary="ModelOnly" class="auth-validation-summary" role="alert"></div>

            <fieldset class="space-y-6 mb-8 pb-6 border-b border-gray-200">
                <legend class="text-xl font-semibold text-gray-700 mb-4">Bericht aan Geselecteerden</legend>
                <div class="auth-form-group">
                    <label asp-for="SelectedSubject" class="auth-form-label">Onderwerp</label>
                    <input type="text" asp-for="SelectedSubject" class="auth-input-field" />
                    <span asp-validation-for="SelectedSubject" class="auth-validation-message"></span>
                </div>
            
                <div class="auth-form-group">
                    <label asp-for="SelectedMessage" class="auth-form-label">Bericht</label>
                    <textarea asp-for="SelectedMessage" class="auth-input-field" rows="5">@Model.SelectedMessage</textarea>
                    <span asp-validation-for="SelectedMessage" class="auth-validation-message"></span>
                </div>
            </fieldset>

            <fieldset class="space-y-6 mb-8 pb-6 border-b border-gray-200">
                <legend class="text-xl font-semibold text-gray-700 mb-4">Bericht aan Reserves</legend>
                <div class="auth-form-group">
                    <label asp-for="ReserveSubject" class="auth-form-label">Onderwerp</label>
                    <input type="text" asp-for="ReserveSubject" class="auth-input-field" />
                    <span asp-validation-for="ReserveSubject" class="auth-validation-message"></span>
                </div>

                <div class="auth-form-group">
                    <label asp-for="ReserveMessage" class="auth-form-label">Bericht</label>
                    <textarea asp-for="ReserveMessage" class="auth-input-field" rows="5" >@Model.ReserveMessage</textarea>
                    <span asp-validation-for="ReserveMessage" class="auth-validation-message"></span>
                </div>
            </fieldset>

            <fieldset class="space-y-6">
                <legend class="text-xl font-semibold text-gray-700 mb-4">Bericht aan Niet Geselecteerden</legend>
                <div class="auth-form-group">
                    <label asp-for="NotSelectedSubject" class="auth-form-label">Onderwerp</label>
                    <input type="text" asp-for="NotSelectedSubject" class="auth-input-field" />
                    <span asp-validation-for="NotSelectedSubject" class="auth-validation-message"></span>
                </div>

                <div class="auth-form-group">
                    <label asp-for="NotSelectedMessage" class="auth-form-label">Bericht</label>
                    <textarea asp-for="NotSelectedMessage" class="auth-input-field" rows="4" >@Model.NotSelectedMessage</textarea>
                    <span asp-validation-for="NotSelectedMessage" class="auth-validation-message"></span>
                </div>
            </fieldset>

            <div class="message-edit-form-actions">
                <button type="submit" class="btn btn-success btn-lg">Bevestig berichten</button> 
            </div>
        </form>
    </div>
</div>
