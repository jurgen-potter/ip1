@model CreatePanelViewModel

@{
    ViewBag.Title = "Panel maken";
}

<h2>Begin met uw panel te maken</h2>
<form asp-controller="Panel" asp-action="CreatePanel" method="post">
    <div>
        <label>Naam van uw panel:</label>
        <input asp-for="Name" type="text" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div>
        <label>Beschrijving van uw panel:</label>
        <textarea rows="5" asp-for="Description" type="number" class="form-control">Geef hier uw beschrijving</textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    
    <div>
        @if (Model.Result.CriteriaResults != null)
        {
            @for (int i = 0; i < Model.Result.CriteriaResults.Count; i++)
            {
                <input type="hidden" asp-for="Result.CriteriaResults[i].Name"/>

                @for (int j = 0; j < Model.Result.CriteriaResults[i].SubResults.Count; j++)
                {
                    <input type="hidden" asp-for="Result.CriteriaResults[i].SubResults[j].Name"/>
                    <input type="hidden" asp-for="Result.CriteriaResults[i].SubResults[j].Count"/>
                    <input type="hidden" asp-for="Result.CriteriaResults[i].SubResults[j].Percentage"/>
                }
            }
        }

        <input type="hidden" asp-for="@Model.Result.Age18_25Count"/>
        <input type="hidden" asp-for="@Model.Result.Age26_40Count"/>
        <input type="hidden" asp-for="@Model.Result.Age41_60Count"/>
        <input type="hidden" asp-for="@Model.Result.Age60PlusCount"/>
        <input type="hidden" asp-for="@Model.Result.MaleCount"/>
        <input type="hidden" asp-for="@Model.Result.FemaleCount"/>
        <input type="hidden" asp-for="@Model.Result.TotalNeededPanelmembers"/>
        <input type="hidden" asp-for="@Model.Result.ReservePotPanelmembers"/>

    </div>
    
    <div>
        <button type="submit" class="btn btn-primary">Maak uw panel</button>
    </div>
</form>