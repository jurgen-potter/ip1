@model CitizenPanel.UI.MVC.Models.Panels.PanelViewModel

@using System.Globalization
@using Microsoft.AspNetCore.Mvc.TagHelpers
@{
    CultureInfo.CurrentCulture = new CultureInfo("nl-NL");
    CultureInfo.CurrentUICulture = new CultureInfo("nl-NL");
}
@section Styles {
    <link rel="stylesheet" href="~/dist/clientapp/assets/index.css">
}
@{
    ViewBag.Title = Model.Name;
    // Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/dist/css/panel/dashboard.css" asp-append-version="true"/>
<link rel="stylesheet" href="~/dist/clientapp/assets/index.css" asp-append-version="true"/>

<div class="container mx-auto p-4" data-panel-id="@Model.PanelId">

    <div class="flex justify-between items-center border-b pb-3 mb-4">
        <h1 class="text-xl font-semibold mb-0">@Model.Name</h1>
        @if (User.IsInRole("Organization"))
        {
            <div class="flex gap-2">
                <a asp-controller="Registration" asp-action="Index" asp-route-panelId="@Model.PanelId" class="btn-secondary">
                    <i class="fas fa-eye btn-icon-left"></i> Aanmeldingen Bekijken
                </a>
                <a asp-controller="Panel" asp-action="Invitations" asp-route-panelId="@Model.PanelId" class="btn-primary">
                    <i class="fas fa-eye btn-icon-left"></i> Uitnodigingen bekijken
                </a>
                <a asp-page="/Account/RegisterMember" asp-area="Identity" asp-route-staff="true" asp-route-panelId="@Model.PanelId" class="btn-primary">
                    <i class="fas fa-user-plus btn-icon-left"></i> Voeg panellid toe
                </a>
            </div>
        }
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-12 gap-4">

        <div class="md:col-span-1 lg:col-span-3">
            <aside class="timeline-sidebar bg-gray-50 p-3 rounded border h-full">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-xs font-bold uppercase text-gray-500">Tijdlijn</h3>
                    @if (User.IsInRole("Organization"))
                    {
                        <button class="btn-success" data-bs-toggle="modal" data-bs-target="#createMeetingModal">
                            <i class="fas fa-plus btn-icon"></i> Nieuw
                        </button>
                    }
                </div>
                <div class="timeline-line">
                    @foreach (var meeting in Model.Meetings.OrderBy(m => m.Date))
                    {
                        <div class="timeline-item" data-meeting-id="@meeting.Id" data-date="@meeting.Date.ToString("o")">
                            <div class="timeline-box">
                                <div class="date">@meeting.Date.ToString("dd MMM")</div>
                                <h4 class="title">@(meeting.Title ?? "Meeting")</h4>
                            </div>
                        </div>
                    }
                </div>
            </aside>
        </div>

        <div class="md:col-span-3 lg:col-span-9">
            <main class="flex flex-col gap-4">

                <section class="bg-white rounded-lg shadow-sm">
                    <div class="p-4">
                        <h5 class="text-lg font-medium mb-3">Beschrijving</h5>
                        <p class="text-gray-700">@Model.Description</p>
                    </div>
                </section>

                <section class="bg-white rounded-lg shadow-sm">
                    <div class="bg-white p-4 flex justify-between items-center border-b">
                        <h5 class="text-lg font-medium mb-0">Aanbevelingen</h5>
                        <a class="btn-primary" asp-route-panelId="@Model.PanelId" asp-controller="Recommendation" asp-action="Index">
                            Aanbevelingen bekijken 
                            <i class="fas fa-chart-bar btn-icon-right"></i>
                        </a>
                    </div>
                    <div class="p-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            @foreach (var meeting in Model.Meetings)
                            {
                                @foreach (var rec in meeting.Recommendations)
                                {
                                    <div class="col-span-1">
                                        <div class="border p-3 rounded bg-gray-50 h-full flex flex-col">
                                            <h6 class="font-semibold">@rec.Title</h6>
                                            <p class="text-sm flex-grow">@rec.Description</p>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </section>
            </main>
        </div>
    </div>

    <div class="modal fade" id="createMeetingModal" tabindex="-1" aria-labelledby="createMeetingModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="createMeetingModalLabel">Nieuwe Meeting Toevoegen</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="createMeetingForm" novalidate>
                        <div class="mb-3">
                            <label for="meetingTitle" class="block text-sm font-medium text-gray-700 mb-1">Titel</label>
                            <input type="text" class="w-full rounded-md border-gray-300 shadow-sm focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50" id="meetingTitle" name="Title" required>
                            <div id="errorTitle" class="text-red-600 text-sm mt-1 hidden"></div>
                        </div>
                        <div class="mb-3">
                            <label for="meetingDate" class="block text-sm font-medium text-gray-700 mb-1">Datum</label>
                            <input type="date" class="w-full rounded-md border-gray-300 shadow-sm focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50" id="meetingDate" name="Date" required>
                            <div id="errorDate" class="text-red-600 text-sm mt-1 hidden"></div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-secondary" data-bs-dismiss="modal">Annuleren</button>
                    <button type="submit" form="createMeetingForm" class="btn-primary" id="saveMeetingBtn">Opslaan</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/dist/clientapp/assets/index.js"></script>
}