@model PanelViewModel

@{
ViewBag.Title = Model.Name;
Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/dist/css/panel/dashboard.css" asp-append-version="true" />

<div class="container-fluid p-4">

    <!-- Header Sectie -->
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <h1 class="h3 mb-0">@Model.Name</h1>
        <div class="d-flex gap-2">
            <a asp-controller="Registration" asp-action="Index" asp-route-panelId="@Model.PanelId" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-eye me-1"></i> Aanmeldingen Bekijken
            </a>
            <a asp-action="Edit" asp-route-panelId="@Model.PanelId" class="btn btn-primary btn-sm">
                <i class="bi bi-pencil-square me-1"></i> Edit Panel
            </a>
        </div>
    </div>

    <div class="row g-4">

        <!-- Tijdlijn Kolom -->
        <div class="col-lg-3 col-md-4">
            <aside class="timeline-sidebar bg-light p-3 rounded border h-100">
                <h3 class="h6 fw-bold mb-4 text-uppercase text-muted">Tijdlijn</h3>
                <div class="timeline-line"></div>

                @* Meeting items sorted by date *@
                @foreach (var meeting in Model.Meetings.OrderBy(m => m.Date))
                {
                <div class="timeline-item" data-meeting-id="meeting-@meeting.Date.ToString("yyyyMMdd")">
                    <div class="timeline-box">
                        <div class="date">@meeting.Date.ToString("dd MMM yyyy")</div>
                        <h4 class="title">@(meeting.Recommendations.FirstOrDefault()?.Title ?? "Meeting")</h4>
                    </div>
                </div>
                }

            </aside>
        </div>

        <!-- Hoofdinhoud Kolom -->
        <div class="col-lg-9 col-md-8">
            <main class="main-content d-flex flex-column gap-4">

                <section class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Beschrijving</h5>
                        <p class="card-text">@Model.Description</p>
                    </div>
                </section>

                <section class="card shadow-sm">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Aanbevelingen</h5>
                        <a class="btn btn-primary btn-sm" asp-route-panelId="@Model.PanelId" asp-controller="Recommendation" asp-action="Index">
                            Aanbevelingen bekijken <i class="bi bi-bar-chart-line ms-1"></i>
                        </a>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            @foreach (var rec in Model.Recommendations)
                            {
                            <div class="col-md-6">
                                <div class="border p-3 rounded bg-light h-100 d-flex flex-column">
                                    <h6 class="fw-semibold">@rec.Title</h6>
                                    <p class="small flex-grow-1">@rec.Description</p>
                                </div>
                            </div>
                            }
                        </div>
                    </div>
                </section>
            </main>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/dist/js/panel/timeline.js" asp-append-version="true"></script>
}