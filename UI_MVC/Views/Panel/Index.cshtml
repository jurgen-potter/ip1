@model CitizenPanel.UI.MVC.Models.Panels.PanelViewModel

@using System.Globalization
@using Microsoft.AspNetCore.Mvc.TagHelpers
@{
    CultureInfo.CurrentCulture = new CultureInfo("nl-NL");
    CultureInfo.CurrentUICulture = new CultureInfo("nl-NL");
    ViewBag.Title = Model.Name;
}
@section Styles {
    <link rel="stylesheet" href="~/dist/clientapp/assets/styles.css" asp-append-version="true"/>
}

<div class="panel-detail-container" data-panel-id="@Model.PanelId">

    <div class="panel-detail-header">
        <h1 class="panel-detail-title">@Model.Name</h1>
      
        <div class="panel-detail-actions">
            @if (User.IsInRole("Organization"))
            {
            <a asp-controller="Registration" asp-action="Index" asp-route-panelId="@Model.PanelId" class="btn btn-primary">
                <i class="fas fa-users"></i> Aanmeldingen
            </a>
            <a asp-controller="Panel" asp-action="Invitations" asp-route-panelId="@Model.PanelId" class="btn btn-primary">
                <i class="fas fa-envelope-open-text"></i> Uitnodigingen
            </a>
            <a asp-page="/Account/RegisterMember" asp-area="Identity" asp-route-staff="true" asp-route-panelId="@Model.PanelId" class="btn btn-primary">
                <i class="fas fa-user-plus"></i> Voeg panellid toe
            </a>
            <a asp-controller="Panel" asp-action="Members" asp-route-panelId="@Model.PanelId" class="btn btn-primary btn-sm">
                <i class="fa-solid fa-eye"></i> Panelleden
            </a>
            }
            <a asp-controller="Panel" asp-action="Details" asp-route-panelId="@Model.PanelId" class="btn btn-primary btn-sm">
                <i class="fa-solid fa-table-columns"></i> Projectpagina
            </a>
            @* <a asp-action="Edit" asp-route-panelId="@Model.PanelId" class="btn btn-primary btn-sm"> *@
            @*     <i class="bi bi-pencil-square me-1"></i> Edit Panel *@
            @* </a> *@
        </div>
    </div>

    <div class="panel-detail-grid">

        <div class="timeline-sidebar"> 
            <aside>
                <div class="panel-timeline-header">
                    <h3>Tijdlijn</h3>
                    @if (User.IsInRole("Organization"))
                    {
                        <button type="button" id="openCreateMeetingModalBtn" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Nieuw
                        </button>
                    }
                </div>
                <div class="timeline-line"> 
                    @if (Model.Meetings != null && Model.Meetings.Any())
                    {
                        @foreach (var meeting in Model.Meetings.OrderBy(m => m.Date))
                        {
                            <div class="timeline-item" data-meeting-id="@meeting.Id" data-date="@meeting.Date.ToString("o")">
                                <div class="timeline-box">
                                    <div class="date">@meeting.Date.ToString("dd MMM")</div>
                                    <h4 class="title">@(meeting.Title ?? "Meeting")</h4>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p id="noMeetingsMessage" class="text-sm text-gray-500 italic pl-[30px]">Nog geen meetings gepland.</p>
                    }
                </div>
            </aside>
        </div>

        <div class="panel-main-content">
            <main>
                <section class="panel-content-section">
                    <div class="panel-section-body">
                        <h5 class="text-lg font-medium mb-3">Beschrijving</h5>
                        <p class="panel-description-text">@Model.Description</p>
                    </div>
                </section>

                <section class="panel-content-section">
                    <div class="panel-section-header">
                        <h5>Aanbevelingen</h5>
                        <a class="btn btn-primary" asp-route-panelId="@Model.PanelId" asp-controller="Recommendation" asp-action="Index">
                            Aanbevelingen bekijken 
                            <i class="fas fa-chart-bar"></i>
                        </a>
                    </div>
                    <div class="panel-section-body">
                        @if (Model.Meetings != null && Model.Meetings.SelectMany(m => m.Recommendations).Any())
                        {
                            <div class="panel-recommendations-grid">
                                @foreach (var meeting in Model.Meetings)
                                {
                                    @foreach (var rec in meeting.Recommendations)
                                    {
                                        <div class="panel-recommendation-card">
                                            <h6>@rec.Title</h6>
                                            <p>@rec.Description</p>
                                        </div>
                                    }
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-sm text-gray-500 italic">Nog geen aanbevelingen voor dit panel.</p>
                        }
                    </div>
                </section>
            </main>
        </div>
    </div>

    <div id="createMeetingModal" class="custom-modal-overlay" aria-labelledby="createMeetingModalLabel" role="dialog" aria-modal="true">
        <div class="custom-modal-dialog">
            <div class="custom-modal-header">
                <h5 class="custom-modal-title" id="createMeetingModalLabel">Nieuwe Meeting Toevoegen</h5>
                <button type="button" id="closeCreateMeetingModalBtn" class="custom-modal-close-button" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div class="custom-modal-body">
                <form id="createMeetingForm" novalidate class="space-y-4" asp-controller="Meeting" asp-action="Create">
                    <input type="hidden" name="PanelId" value="@Model.PanelId" />
                    <input type="hidden" name="PanelPartcipants" value="@Model.PanelPartcipants" />
                    <div class="panel-form-group">
                        <label for="meetingTitle" class="auth-form-label">Titel</label>
                        <input type="text" class="auth-input-field" id="meetingTitle" name="Title" required>
                        <div id="errorTitle" class="auth-validation-message mt-1 hidden"></div>
                    </div>
                    <div class="panel-form-group">
                        <label for="meetingDate" class="auth-form-label">Datum</label>
                        <input type="date" class="auth-input-field" id="meetingDate" name="Date" required>
                        <div id="errorDate" class="auth-validation-message mt-1 hidden"></div>
                    </div>
                </form>
            </div>
            <div class="custom-modal-footer">
                <button type="button" id="cancelCreateMeetingBtn" class="btn btn-secondary">Annuleren</button>
                <button type="submit" form="createMeetingForm" class="btn btn-primary" id="saveMeetingBtn">Opslaan</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script type="module" src="~/dist/clientapp/assets/dashboard.js" asp-append-version="true"></script>
}