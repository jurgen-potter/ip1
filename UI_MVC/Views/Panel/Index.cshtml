@model CitizenPanel.UI.MVC.Models.Panels.PanelViewModel

@using System.Globalization
@using Microsoft.AspNetCore.Mvc.TagHelpers
@{
    CultureInfo.CurrentCulture = new CultureInfo("nl-NL");
    CultureInfo.CurrentUICulture = new CultureInfo("nl-NL");
}
@{
    ViewBag.Title = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/dist/css/panel/dashboard.css" asp-append-version="true"/>

<div class="container-fluid p-4" data-panel-id="@Model.PanelId">

    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <h1 class="h3 mb-0">@Model.Name</h1>
        @if (User.IsInRole("Organization"))
        {
            <div class="d-flex gap-2">
                <a asp-controller="Registration" asp-action="Index" asp-route-panelId="@Model.PanelId" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-eye me-1"></i> Aanmeldingen Bekijken
                </a>
                <a asp-controller="Panel" asp-action="Invitations" asp-route-panelId="@Model.PanelId" class="btn btn-primary btn-sm">
                    <i class="bi bi-eye me-1"></i> Uitnodigingen bekijken
                </a>
                <a asp-page="/Account/RegisterMember" asp-area="Identity" asp-route-staff="true" asp-route-panelId="@Model.PanelId" class="btn btn-primary btn-sm">
                    <i class="bi bi-pencil-square me-1"></i> Voeg panellid toe
                </a>
                @* <a asp-action="Edit" asp-route-panelId="@Model.PanelId" class="btn btn-primary btn-sm"> *@
                @*     <i class="bi bi-pencil-square me-1"></i> Edit Panel *@
                @* </a> *@
            </div>
        }
    </div>

    <div class="row g-4">

        <div class="col-lg-3 col-md-4">
            <aside class="timeline-sidebar bg-light p-3 rounded border h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="h6 fw-bold text-uppercase text-muted">Tijdlijn</h3>
                    @if (User.IsInRole("Organization"))
                    {
                        <button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#createMeetingModal">
                            <i class="bi bi-plus-lg"></i> Nieuw
                        </button>
                    }
                </div>
                <div class="timeline-line">
                    @foreach (var meeting in Model.Meetings.OrderBy(m => m.Date))
                    {
                        <div class="timeline-item" data-meeting-id="@meeting.Id" data-date="@meeting.Date.ToString("o")">
                            <div class="timeline-box">
                                <div class="date">@meeting.Date.ToString("dd MMM")</div>
                                <h4 class="title">@(meeting.Title ?? "Meeting")</h4>
                            </div>
                        </div>
                    }
                </div>
            </aside>
        </div>

        <div class="col-lg-9 col-md-8">
            <main class="main-content d-flex flex-column gap-4">

                <section class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Beschrijving</h5>
                        <p class="card-text">@Model.Description</p>
                    </div>
                </section>

                <section class="card shadow-sm">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Aanbevelingen</h5>
                        <a class="btn btn-primary btn-sm" asp-route-panelId="@Model.PanelId" asp-controller="Recommendation" asp-action="Index">
                            Aanbevelingen bekijken <i class="bi bi-bar-chart-line ms-1"></i>
                        </a>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            @foreach (var meeting in Model.Meetings)
                            {
                                @foreach (var rec in meeting.Recommendations)
                                {
                                    <div class="col-md-6">
                                        <div class="border p-3 rounded bg-light h-100 d-flex flex-column">
                                            <h6 class="fw-semibold">@rec.Title</h6>
                                            <p class="small flex-grow-1">@rec.Description</p>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </section>
            </main>
        </div>
    </div>

    <div class="modal fade" id="createMeetingModal" tabindex="-1" aria-labelledby="createMeetingModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="createMeetingModalLabel">Nieuwe Meeting Toevoegen</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="createMeetingForm" novalidate>
                        <div class="mb-3">
                            <label for="meetingTitle" class="form-label">Titel</label>
                            <input type="text" class="form-control" id="meetingTitle" name="Title" required>
                            <div id="errorTitle" class="text-danger small mt-1 d-none"></div>
                        </div>
                        <div class="mb-3">
                            <label for="meetingDate" class="form-label">Datum</label>
                            <input type="date" class="form-control" id="meetingDate" name="Date" required>
                            <div id="errorDate" class="text-danger small mt-1 d-none"></div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuleren</button>
                    <button type="submit" form="createMeetingForm" class="btn btn-primary" id="saveMeetingBtn">Opslaan</button>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="~/dist/js/dashboard/timeline.js" asp-append-version="true"></script>
}