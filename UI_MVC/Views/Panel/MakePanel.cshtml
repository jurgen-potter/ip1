@model CitizenPanel.BL.Domain.Panel.Panel

@{
    ViewBag.Title = "Panel maken";
}

<h2>Begin met uw panel te maken</h2>
<div asp-validation-summary="All" class="text-danger"></div>
<form asp-controller="Panel" asp-action="MakePanel" method="post">
    <label>Naam van uw panel:</label>
    <input asp-for="Name" type="number" class="form-control" required />
    <span asp-validation-for="Name" class="text-danger"></span>

    <label>Beschrijving van uw panel:</label>
    <textarea rows="10" asp-for="Description" type="number" class="form-control" required>Geef hier uw beschrijving</textarea>
    <span asp-validation-for="Description" class="text-danger"></span>


    <button type="submit" class="btn btn-primary">Maak uw panel</button>
</form>