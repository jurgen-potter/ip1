@using CitizenPanel.BL.Domain.Users
@model System.Collections.Generic.IEnumerable<CitizenPanel.BL.Domain.Draws.Invitation>

@{
    ViewBag.Title = "title";
}

<h2>Qr-codes</h2>
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach(var invitation in Model)
    {
        <div class="col d-flex">
            <div class="card h-100 w-100">
                <div class="card-body d-flex flex-column">
                    <p class="card-text flex-grow-1">Geslacht: @invitation.Gender.ToDutch()</p>
                    <p class="card-text flex-grow-1">Leeftijd: 
                        @if (invitation.Age == 18)
                        {
                            @($"18-25")
                        }
                        else if (invitation.Age == 26)
                        {
                            @($"26-35")
                        }
                        else if (invitation.Age == 36)
                        {
                            @($"36-50")
                        }
                        else if (invitation.Age == 51)
                        {
                            @($"51-60")
                        }
                        else if (invitation.Age == 61)
                        {
                            @($"61")
                        }
                    </p>
                    <p class="card-text flex-grow-1">Code: @invitation.Code</p>
                    <img src="data:image/png;base64,@invitation.QRCodeString" style="width: 150px; height: 150px;"/>
                </div>
            </div>
        </div>
    }
</div>