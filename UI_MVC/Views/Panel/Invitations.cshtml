@using CitizenPanel.BL.Domain.Users
@using Microsoft.IdentityModel.Tokens
@model System.Collections.Generic.IEnumerable<CitizenPanel.BL.Domain.Draws.Invitation>

@{
    ViewBag.Title = "Uitnodigingen";
}

<div class="container mx-auto px-4">
    <h2 class="text-2xl font-semibold mb-6">Uitnodigingen</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        @foreach (var invitation in Model.Where(i => !i.IsRegistered))
        {
            <div class="flex">
                <div class="bg-white rounded-lg shadow-md overflow-hidden w-full">
                    <div class="p-4 flex flex-col h-full">
                        <p class="mb-2 flex-grow">Geslacht: @invitation.Gender.ToDutch()</p>
                        <p class="mb-2 flex-grow">Leeftijd:
                            @if (invitation.Age == 18)
                            {
                                @($"18-25")
                            }
                            else if (invitation.Age == 26)
                            {
                                @($"26-35")
                            }
                            else if (invitation.Age == 36)
                            {
                                @($"36-50")
                            }
                            else if (invitation.Age == 51)
                            {
                                @($"51-60")
                            }
                            else if (invitation.Age == 61)
                            {
                                @($"61")
                            }
                        </p>
                        <p class="mb-2 flex-grow">Code: @invitation.Code</p>
                        <div class="flex-grow">
                            @if (@invitation.QRCodeString.IsNullOrEmpty())
                            {
                                <strong class="text-red-600">@($"Deze invitation heeft geen QR-code meer")</strong>
                            }
                            else
                            {
                                <img src="data:image/png;base64,@invitation.QRCodeString" class="w-[150px] h-[150px]"/>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>