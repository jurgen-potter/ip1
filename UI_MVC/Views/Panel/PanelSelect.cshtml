@using Microsoft.AspNetCore.Mvc.TagHelpers
@model CitizenPanel.UI.MVC.Models.Panels.PanelSelectViewModel

@{
    ViewData["Title"] = "Kies uw panel";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">Kies uw panel</h2>
                </div>
                <div class="card-body">
                    <p class="lead mb-4">Kies het panel wat u wil openen:</p>
                    
                    <div class="list-group">
                        @foreach (var panel in Model.Panels)
                        {
                            <a asp-action="Index" asp-route-id="@panel.Id" class="list-group-item list-group-item-action d-flex align-items-center">
                                <div class="panel-icon me-3">
                                    <i class="fas fa-clipboard-list fa-2x text-primary"></i>
                                </div>
                                <div>
                                    <h5 class="mb-1">@panel.Name</h5>
                                </div>
                                <div class="ms-auto">
                                    <i class="fas fa-chevron-right text-secondary"></i>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>