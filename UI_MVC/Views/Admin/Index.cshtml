@using Microsoft.AspNetCore.Mvc.TagHelpers
@model CitizenPanel.UI.MVC.Models.QuestionnaireModules.QuestionnaireSelectViewModel
@{
    ViewBag.Title = "Platformbeheer";
}
@section Styles {
    <link rel="stylesheet" href="~/dist/clientapp/assets/styles.css" asp-append-version="true"/>
}

<div class="admin-platform-container">
    <h2 class="admin-platform-title">@ViewBag.Title</h2>

    <div class="admin-platform-actions-card">
        <div class="admin-platform-actions-list">
            <a asp-page="/Account/RegisterAdmin" asp-area="Identity" class="btn btn-primary">
                <i class="fas fa-user-shield mr-2"></i> Voeg nieuwe admin toe
            </a>

            @if (Model.Questionnaires != null && Model.Questionnaires.Any())
            {
                @foreach (var questionnaire in @Model.Questionnaires)
                {
                    <a asp-controller="Admin" asp-action="EditQuestionnaire" asp-route-questionnaireId="@questionnaire.Id" class="btn btn-primary">
                        <i class="fas fa-edit mr-2"></i> Bewerk vragenlijst: @questionnaire.Title
                    </a>
                }
            }
            else
            {
                <p class="text-center text-gray-500">Er zijn geen vragenlijsten beschikbaar om te bewerken.</p>
            }
        </div>
    </div>
</div>