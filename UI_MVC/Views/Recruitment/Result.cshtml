@using Microsoft.AspNetCore.Mvc.TagHelpers
@model CitizenPanel.UI.MVC.Models.Draws.ResultViewModel
@{
    ViewData["Title"] = "Berekening Panel";
    var panelId = ViewBag.PanelId;
    var panelName = ViewBag.PanelName;
    var criteriaNamesLookup = ViewBag.CriteriaNames as Dictionary<int, string> ?? new Dictionary<int, string>();
}
@section Styles {
    <link rel="stylesheet" href="~/dist/clientapp/assets/styles.css" asp-append-version="true"/>
}

<div class="reg-overview-container"> 
    <h2 class="draw-calc-page-title">Resultaten panelgrootte berekening</h2>

    <div class="reg-overview-alert alert-info">
        <strong>@Model.TotalNeededInvitations</strong> burgers moeten uitgenodigd worden om het benodigde aantal panelleden te bereiken.
    </div>

    <div class="summary-section">
        <div class="reg-overview-card summary-card">
            <div class="draw-calc-summary-header">
                <h5>Samenvatting</h5>
            </div>
            <div class="reg-overview-card-body">
                <p><strong>Geadviseerd aantal panelleden voor een panel voor uw gemeente:</strong> <span class="reg-overview-status-badge status-secondary">@Model.TotalNeededPanelmembers</span></p>
            </div>
        </div>

        <div class="reg-overview-card panel-members-card">
            <div class="draw-calc-summary-header">
                <h5>Aanpassen</h5>
            </div>
            <div class="reg-overview-card-body">
                <form asp-action="Recalculate" method="post" class="panel-members-form">
                    @if (Model.Criteria != null)
                    {
                        @for (int i = 0; i < Model.Criteria.Count; i++)
                        {
                            <input type="hidden" name="Criteria[@i].Name" value="@Model.Criteria[i].Name"/>

                            @for (int j = 0; j < Model.Criteria[i].SubCriteria.Count; j++)
                            {
                                <input type="hidden" name="Criteria[@i].SubCriteria[@j].Name" value="@Model.Criteria[i].SubCriteria[j].Name"/>
                                <input type="hidden" name="Criteria[@i].SubCriteria[@j].Percentage" value="@Model.Criteria[i].SubCriteria[j].Percentage"/>
                            }
                        }
                    }
                    <input type="hidden" asp-for="@Model.TotalAvailablePotentialPanelmembers" />
                    <input type="hidden" asp-for="@Model.TotalNeededInvitations" />
                    
                    <div class="panel-members-input-group">
                        <label asp-for="TotalNeededPanelmembers">Eigen aantal gewenste panelleden</label>
                        <div class="input-with-button">
                            <input asp-for="TotalNeededPanelmembers" type="number" class="auth-input-field" min="1" />
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-calculator"></i>
                                Herbereken
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @if (Model.Buckets != null && Model.Buckets.Any())
    {
        <h3 class="text-xl font-semibold text-gray-700 mb-4">Details per doelgroep:</h3>
        <div class="draw-calc-bucket-list">
            @foreach(var bucket in Model.Buckets)
            {
                <div class="draw-calc-bucket-card">
                    <h5 class="draw-calc-bucket-title">
                        @(string.Join(" × ", bucket.SubCriteriaNames
                        .Select((sub, idx) => $"{sub} ({bucket.CriteriaNames[idx]})")))
                    </h5>
                    <p class="draw-calc-bucket-text">
                        Nodig: <strong>@bucket.Count</strong>
                    </p>
                </div>
            }
        </div>
    }

    <form asp-controller="Recruitment" asp-action="ReadResult" method="post">
        @if (Model.Criteria != null)
        {
            @for (int i = 0; i < Model.Criteria.Count; i++)
            {
                <input type="hidden" name="Criteria[@i].Name" value="@Model.Criteria[i].Name"/>

                @for (int j = 0; j < Model.Criteria[i].SubCriteria.Count; j++)
                {
                    <input type="hidden" name="Criteria[@i].SubCriteria[@j].Name" value="@Model.Criteria[i].SubCriteria[j].Name"/>
                    <input type="hidden" name="Criteria[@i].SubCriteria[@j].Percentage" value="@Model.Criteria[i].SubCriteria[j].Percentage"/>
                }
            }
        }
        <input type="hidden" asp-for="@Model.TotalAvailablePotentialPanelmembers" />
        <input type="hidden" asp-for="@Model.TotalNeededPanelmembers" />
        <input type="hidden" asp-for="TotalNeededInvitations" />

        @if (Model.Buckets != null) // Null check voor Buckets
        {
            @foreach(var bucket in Model.Buckets)
            {
                @for (int i = 0; i < bucket.CriteriaNames.Count; i++)
                {
                    <input type="hidden" name="Buckets[@(Model.Buckets.IndexOf(bucket))].CriteriaNames[@i]" value="@bucket.CriteriaNames[i]"/>
                    <input type="hidden" name="Buckets[@(Model.Buckets.IndexOf(bucket))].SubCriteriaNames[@i]" value="@bucket.SubCriteriaNames[i]"/>
                }
                <input type="hidden" name="Buckets[@(Model.Buckets.IndexOf(bucket))].Count" value="@bucket.Count"/>
            }
        }

        <div class="draw-calc-actions">
            <button type="submit" class="btn btn-success">Maak uw panel</button>
            <a href="@Url.Action("Index", "Recruitment")" class="btn btn-outline-secondary">Nieuwe berekening</a>
        </div>
    </form>
</div>
