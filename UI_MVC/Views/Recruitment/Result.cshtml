@model CitizenPanel.BL.Domain.Draw.RecruitmentResult

@{
    ViewBag.Title = "Berekening Panel";
}

<div class="container my-4">
    <h2 class="mb-4 text-primary">Resultaten Panelberekening</h2>

    <div class="alert alert-info">
        <strong>@Model.ReservePotPanelmembers</strong> burgers moeten uitgenodigd worden om het benodigde aantal panelleden te bereiken.
    </div>

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            Samenvatting
        </div>
        <div class="card-body">
            <p><strong>Benodigde Panelleden:</strong> <span class="badge bg-secondary">@Model.TotalNeededPanelmembers</span></p>
        </div>
    </div>

    @foreach(var bucket in Model.Buckets)
    {
        <div class="card m-2 p-2">
            <div class="card-body">
                <h5 class="card-title">
                    @bucket.Description  @* bijv. “Mannen (Gender) × Fietsers (Transport)” *@
                </h5>
                <p class="card-text">
                    Nodig: <strong>@bucket.Count</strong>
                </p>
            </div>
        </div>
    }

    <div class="d-flex justify-content-start mt-4 gap-2">
        <a href="@Url.Action("MakePanel", "Panel")" class="btn btn-success">Maak uw panel</a>
        <a href="@Url.Action("Index", "Recruitment")" class="btn btn-outline-secondary">Nieuwe berekening</a>
    </div>
</div>
