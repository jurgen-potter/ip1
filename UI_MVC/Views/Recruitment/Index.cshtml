@using Microsoft.AspNetCore.Mvc.TagHelpers
@model RecruitmentCriteriaViewModel

@section Styles {
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
}

@{
ViewBag.Title = "Bereken panel";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Wervingscriteria</h2>
    <button type="button" class="btn btn-outline-primary btn-sm" id="toggle-all-btn">
        Alles invouwen
    </button>
</div>

<form asp-action="Calculate" method="post">
    <input asp-for="PanelId" type="hidden" />
    <div class="mb-3">
        <label class="form-label">Aantal inwoners gemeente</label>
        <input asp-for="TotalAvailablePotentialPanelmembers" type="number" class="form-control" required />
    </div>

    <ul id="criterias-list" class="list-unstyled">
        @for (int i = 0; i < Model.Criteria.Count; i++)
        {
        <li class="card mb-3 criteria-item">
            <input asp-for="Criteria[i].Id" type="hidden" />
            <div class="card-header d-flex align-items-start">
                <div class="flex-grow-1">
                    <label class="form-label fw-bold">Criteria @(i + 1)</label>
                    <div class="d-flex align-items-center w-100">
                        <input asp-for="Criteria[i].Name"
                               class="form-control mb-0 criteria-description"
                               placeholder="Criteria omschrijving" />
                        <button type="button" class="btn btn-danger btn-sm ms-2 remove-criteria-btn">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
                <button class="btn btn-sm expand-btn ms-2"
                        data-bs-toggle="collapse"
                        data-bs-target="#criteria-body-@i"
                        type="button">
                    <i class="bi bi-chevron-up"></i>
                </button>
            </div>

            <div class="collapse show criteria-body" id="criteria-body-@i">
                <div class="card-body">
                    <label class="form-label fw-bold">Subcriteria</label>
                    <ul id="subcriterias-list-@i" class="list-unstyled">
                        @for (int j = 0; j < Model.Criteria[i].SubCriteria.Count; j++)
                        {
                        <li class="row subcriteria-item mb-2 align-items-center p-2">
                            <input asp-for="Criteria[i].SubCriteria[j].Id" type="hidden" />
                            <div class="col">
                                <input asp-for="Criteria[i].SubCriteria[j].Name"
                                       class="form-control subcriteria-description"
                                       placeholder="Subcriteria omschrijving" />
                            </div>
                            <div class="col-auto">
                                <div class="input-group">
                                    <input asp-for="Criteria[i].SubCriteria[j].Percentage"
                                           class="form-control subcriteria-percentage"
                                           type="number" min="0" max="100" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                            <div class="col-auto">
                                <button type="button" class="btn btn-danger btn-sm remove-subcriteria-btn">
                                    Verwijder
                                </button>
                            </div>
                        </li>
                        }
                    </ul>

                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <button type="button"
                                class="btn btn-sm btn-secondary add-subcriteria-btn"
                                criteria-index="@i">
                            Voeg een subcriteria toe
                        </button>
                        <div class="subcriteria-total mt-2 text-end small">
                            Totaal: <span class="subcriteria-sum">0</span>%
                            <span class="text-danger subcriteria-warning" style="display:none;">
                                    (moet 100%)
                                </span>
                        </div>
                    </div>
                </div>
            </div>
        </li>
        }
    </ul>

    <button type="button" id="add-criteria-btn" class="btn btn-secondary mb-3">Voeg criteria toe</button>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Bereken</button>
        <button type="submit" formaction="@Url.Action("Save", "Recruitment")" class="btn btn-success">Opslaan</button>
    </div>
</form>

@section Scripts {
<script defer src="~/dist/js/draw/demographicData.js"></script>
}