@using Microsoft.AspNetCore.Mvc.TagHelpers
@model CitizenPanel.UI.MVC.Models.Draws.RecruitmentCriteriaViewModel

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        /* Voeg stijlen toe voor readonly inputs */
        input[readonly] {
            background-color: #f3f4f6;
            cursor: not-allowed;
        }
        
        /* Consistent button heights */
        .remove-criteria-btn, .remove-subcriteria-btn {
            height: 42px; /* Same as input height (38px + 2px border top/bottom) */
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        /* Smooth transition for collapse/expand */
        .criteria-body {
            overflow: hidden;
            transition: height 0.3s ease-out;
            will-change: height;
        }
        
        .criteria-body.hidden {
            height: 0 !important;
            padding-top: 0;
            padding-bottom: 0;
            margin-top: 0;
            margin-bottom: 0;
            border-width: 0;
        }
        
        /* Danger button styling */
        .btn-danger {
            background-color: #EF4444;
            color: white;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            transition: background-color 0.15s ease-in-out;
        }
        
        .btn-danger:hover {
            background-color: #DC2626;
        }
    </style>
}

@{
    ViewBag.Title = "Bereken panel";
}

<div class="flex justify-between items-center mb-3">
    <h2 class="mb-0 text-2xl font-bold">Wervingscriteria</h2>
    <button type="button" class="px-3 py-2 text-sm border border-primary text-primary hover:bg-primary hover:text-white rounded-lg transition-colors duration-150" id="toggle-all-btn">
        Alles invouwen
    </button>
</div>

<form asp-action="Calculate" method="post">
    <input asp-for="PanelId" type="hidden"/>
    <div class="mb-3">
        <label class="block text-sm font-medium mb-1">Aantal inwoners gemeente</label>
        <input asp-for="TotalAvailablePotentialPanelmembers" type="number" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary" required/>
        <span asp-validation-for="@Model.TotalAvailablePotentialPanelmembers" class="text-red-500 text-sm"></span>
    </div>

    <ul id="criterias-list" class="space-y-3 list-none p-0">
        @for (int i = 0; i < Model.Criteria.Count; i++)
        {
            if (i == 0 || i == 1)
            {
                <li class="bg-white rounded-lg shadow-md overflow-hidden criteria-item">
                    <input asp-for="Criteria[i].Id" type="hidden"/>
                    <div class="px-4 py-3 bg-gray-50 border-b flex items-start">
                        <div class="flex-grow w-full">
                            <label class="block text-sm font-bold mb-1">Criteria</label>

                            <div class="flex items-start gap-2">
                                <div class="flex-grow">
                                    <input asp-for="Criteria[i].Name"
                                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary criteria-description" readonly/>
                                </div>
                            </div>
                        </div>
                        <button class="ml-2 p-1 text-sm expand-btn"
                                type="button"
                                data-tw-toggle="collapse"
                                data-tw-target="#criteria-body-@i">
                            <i class="bi bi-chevron-up"></i>
                        </button>
                    </div>

                    <div class="criteria-body" id="criteria-body-@i">
                        <div class="p-4">
                            <label class="block text-sm font-bold mb-2">Subcriteria</label>
                            <ul id="subcriterias-list-@i" class="space-y-2 list-none p-0">
                                @for (int j = 0; j < Model.Criteria[i].SubCriteria.Count; j++)
                                {
                                    <li class="flex flex-wrap items-center p-2 subcriteria-item">
                                        <input asp-for="Criteria[i].SubCriteria[j].Id" type="hidden"/>
                                        <div class="flex-grow">
                                            <input asp-for="Criteria[i].SubCriteria[j].Name"
                                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary subcriteria-description" readonly/>
                                        </div>
                                        <div class="ml-2">
                                            <div class="flex items-center">
                                                <input asp-for="Criteria[i].SubCriteria[j].Percentage"
                                                       class="w-20 px-3 py-2 border border-gray-300 rounded-l-lg focus:ring-2 focus:ring-primary focus:border-primary subcriteria-percentage"
                                                       type="number" min="0" max="100"/>
                                                <span class="inline-flex items-center px-3 py-2 rounded-r-lg border border-l-0 border-gray-300 bg-gray-50">%</span>
                                            </div>
                                        </div>
                                    </li>
                                }
                            </ul>

                            <div class="mt-2 text-right text-sm">
                                Totaal: <span class="subcriteria-sum">0</span>%
                                <span class="text-red-500 subcriteria-warning" style="display:none;">
                                    (moet 100%)
                                </span>
                            </div>
                        </div>
                    </div>
                </li>
            }
            else
            {
                <li class="bg-white rounded-lg shadow-md overflow-hidden criteria-item">
                    <input asp-for="Criteria[i].Id" type="hidden"/>
                    <div class="px-4 py-3 bg-gray-50 border-b flex items-start">
                        <div class="flex-grow w-full">
                            <label class="block text-sm font-bold mb-1">Criteria</label>

                            <div class="flex items-start gap-2">
                                <div class="flex-grow">
                                    <input asp-for="Criteria[i].Name"
                                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary criteria-description"
                                           placeholder="Criteria omschrijving"/>
                                    <span asp-validation-for="@Model.Criteria[@i].Name"
                                          class="text-red-500 text-sm"></span>
                                </div>

                                <button type="button" class="btn-danger remove-criteria-btn">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                        <button class="ml-2 p-1 text-sm expand-btn"
                                type="button"
                                data-tw-toggle="collapse"
                                data-tw-target="#criteria-body-@i">
                            <i class="bi bi-chevron-up"></i>
                        </button>
                    </div>

                    <div class="criteria-body" id="criteria-body-@i">
                        <div class="p-4">
                            <label class="block text-sm font-bold mb-2">Subcriteria</label>
                            <ul id="subcriterias-list-@i" class="space-y-2 list-none p-0">
                                @for (int j = 0; j < Model.Criteria[i].SubCriteria.Count; j++)
                                {
                                    <li class="flex flex-wrap items-center p-2 subcriteria-item">
                                        <input asp-for="Criteria[i].SubCriteria[j].Id"
                                               name="Criteria[@i].SubCriteria.Index"
                                               type="hidden" value="@j"/>
                                        <div class="flex-grow">
                                            <input asp-for="Criteria[i].SubCriteria[j].Name"
                                                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary subcriteria-description"
                                                   placeholder="Subcriteria omschrijving"/>
                                            <span asp-validation-for="@Model.Criteria[@i].SubCriteria[@j].Name"
                                                  class="text-red-500 text-sm"></span>
                                        </div>
                                        <div class="ml-2">
                                            <div class="flex items-center">
                                                <input asp-for="Criteria[i].SubCriteria[j].Percentage"
                                                       class="w-20 px-3 py-2 border border-gray-300 rounded-l-lg focus:ring-2 focus:ring-primary focus:border-primary subcriteria-percentage"
                                                       type="number" min="0" max="100"/>
                                                <span class="inline-flex items-center px-3 py-2 rounded-r-lg border border-l-0 border-gray-300 bg-gray-50">%</span>
                                            </div>
                                        </div>
                                        <div class="ml-2">
                                            <button type="button" class="btn-danger remove-subcriteria-btn">
                                                Verwijder
                                            </button>
                                        </div>
                                    </li>
                                }
                            </ul>

                            <div class="flex justify-between items-center mt-2">
                                <button type="button"
                                        class="bg-accent hover:bg-accent-hover text-text-black px-3 py-2 rounded-lg text-sm add-subcriteria-btn"
                                        criteria-index="@i">
                                    Voeg een subcriteria toe
                                </button>
                                <div class="text-sm">
                                    Totaal: <span class="subcriteria-sum">0</span>%
                                    <span class="text-red-500 subcriteria-warning" style="display:none;">
                                        (moet 100%)
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </li>
            }
        }
    </ul>

    <button type="button" id="add-criteria-btn" class="bg-accent hover:bg-accent-hover text-text-black px-4 py-2 rounded-lg transition-colors duration-150 mb-3">Voeg criteria toe</button>

    <div class="flex gap-2">
        <button
            type="submit"
            formaction="@Url.Action("Calculate")"
            class="bg-accent hover:bg-accent-hover text-text-black px-4 py-2 rounded-lg transition-colors duration-150"
            id="calculate-btn">
            Berekenen
        </button>
    </div>
</form>

@section Scripts {
    <script defer src="~/dist/js/tailwind-components.js"></script>
    <script defer src="~/dist/js/recruitment/index.js"></script>
    <script>
        // Initialize expand/collapse buttons on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Track animation state to prevent interruptions
            const animatingElements = new Set();
            
            // Initialize all criteria bodies with their natural height
            document.querySelectorAll('.criteria-body').forEach(function(body) {
                if (!body.classList.contains('hidden')) {
                    body.style.height = 'auto';
                } else {
                    body.style.height = '0';
                }
            });
            
            // Function to handle smooth toggle
            function smoothToggle(targetEl) {
                // Prevent animation conflicts
                if (animatingElements.has(targetEl.id)) {
                    return;
                }
                
                // Mark this element as animating
                animatingElements.add(targetEl.id);
                
                if (targetEl.classList.contains('hidden')) {
                    // EXPAND
                    console.log('Expanding:', targetEl.id);
                    
                    // 1. Remove hidden class and set initial height
                    targetEl.classList.remove('hidden');
                    targetEl.style.height = '0';
                    
                    // 2. Force browser to acknowledge the initial state
                    void targetEl.offsetHeight;
                    
                    // 3. Set final height to trigger animation
                    const height = targetEl.scrollHeight;
                    targetEl.style.height = height + 'px';
                    
                    // 4. After animation completes, set to auto and clear animation state
                    setTimeout(function() {
                        targetEl.style.height = 'auto';
                        animatingElements.delete(targetEl.id);
                        console.log('Expand complete:', targetEl.id);
                    }, 350); // Slightly longer than transition duration
                } else {
                    // COLLAPSE
                    console.log('Collapsing:', targetEl.id);
                    
                    // 1. Set explicit height based on current content
                    const height = targetEl.scrollHeight;
                    targetEl.style.height = height + 'px';
                    
                    // 2. Force browser to acknowledge the initial state
                    void targetEl.offsetHeight;
                    
                    // 3. Set height to zero to trigger animation
                    targetEl.style.height = '0';
                    
                    // 4. After animation completes, add hidden class and clear animation state
                    setTimeout(function() {
                        targetEl.classList.add('hidden');
                        animatingElements.delete(targetEl.id);
                        console.log('Collapse complete:', targetEl.id);
                    }, 350); // Slightly longer than transition duration
                }
            }
            
            // Make the smooth toggle function globally available
            window.smoothToggle = smoothToggle;
            
            // Override the toggle functions in index.js to use our smooth animation
            // Important: Do this before any event handlers are attached
            if (typeof cToggleArrow === 'function') {
                window.cToggleArrow = function(btn) {
                    if (!btn) return;
                    
                    // Toggle icon
                    const icon = btn.querySelector('i');
                    icon?.classList.toggle('bi-chevron-up');
                    icon?.classList.toggle('bi-chevron-down');
                    
                    // Get target and toggle it
                    const targetId = btn.getAttribute('data-tw-target')?.replace('#', '');
                    if (!targetId) return;
                    
                    const targetEl = document.getElementById(targetId);
                    if (targetEl) {
                        smoothToggle(targetEl);
                    }
                };
            }
            
            if (typeof cToggleExpandAll === 'function') {
                window.cToggleExpandAll = function(btn) {
                    const isCollapsing = !window.allCriteriaCollapsed;
                    
                    document.querySelectorAll('.criteria-body').forEach(function(body) {
                        if (isCollapsing) {
                            // If not already hidden, collapse it
                            if (!body.classList.contains('hidden') && !animatingElements.has(body.id)) {
                                // Mark as animating
                                animatingElements.add(body.id);
                                
                                // 1. Set explicit height
                                const height = body.scrollHeight;
                                body.style.height = height + 'px';
                                
                                // 2. Force browser to acknowledge the initial state
                                void body.offsetHeight;
                                
                                // 3. Set height to zero to trigger animation
                                body.style.height = '0';
                                
                                // 4. After animation completes, add hidden class and clear animation state
                                setTimeout(function() {
                                    body.classList.add('hidden');
                                    animatingElements.delete(body.id);
                                }, 350); // Slightly longer than transition duration
                            }
                        } else {
                            // If hidden, expand it
                            if (body.classList.contains('hidden') && !animatingElements.has(body.id)) {
                                // Mark as animating
                                animatingElements.add(body.id);
                                
                                // 1. Remove hidden class and set initial height
                                body.classList.remove('hidden');
                                body.style.height = '0';
                                
                                // 2. Force browser to acknowledge the initial state
                                void body.offsetHeight;
                                
                                // 3. Set final height to trigger animation
                                const height = body.scrollHeight;
                                body.style.height = height + 'px';
                                
                                // 4. After animation completes, set to auto and clear animation state
                                setTimeout(function() {
                                    body.style.height = 'auto';
                                    animatingElements.delete(body.id);
                                }, 350); // Slightly longer than transition duration
                            }
                        }
                    });
                    
                    window.allCriteriaCollapsed = !window.allCriteriaCollapsed;
                    if (btn) btn.innerHTML = window.allCriteriaCollapsed ? 'Alles uitvouwen' : 'Alles invouwen';
                    
                    document.querySelectorAll('.expand-btn').forEach(function(b) {
                        const icon = b.querySelector('i');
                        if (!icon) return;
                        icon.classList.toggle('bi-chevron-up', !window.allCriteriaCollapsed);
                        icon.classList.toggle('bi-chevron-down', window.allCriteriaCollapsed);
                    });
                };
            }
            
            // Add direct click handlers to all expand buttons to ensure they work
            document.querySelectorAll('.expand-btn').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    // Prevent default and stop propagation to avoid conflicts
                    e.preventDefault();
                    e.stopPropagation();
                    
                    // Call our custom toggle function directly
                    window.cToggleArrow(btn);
                }, true);
            });
        });
    </script>
}