@using Microsoft.AspNetCore.Mvc.TagHelpers
@model CitizenPanel.UI.MVC.Models.RegisterViewModel

@{
    ViewBag.Title = "Vul uw gegevens in";
    var isLoggedIn = User.Identity is { IsAuthenticated: true };
}
@section Styles {
    <link rel="stylesheet" href="~/dist/clientapp/assets/styles.css" asp-append-version="true"/>
}

<div class="auth-page-wrapper">
    <div class="auth-card-container">
        <h2 class="auth-page-title">@ViewBag.Title</h2>
        <div asp-validation-summary="ModelOnly" class="auth-validation-summary mb-4" role="alert"></div>
        <form asp-controller="MemberRegister" asp-action="RegisterMember" asp-route-code="@Model.Code" method="post">
            <div class="member-reg-form-group">
                <label asp-for="Email" class="auth-form-label">Email:</label>
                <input name="Email"
                       type="email"
                       class="auth-input-field"
                       value="@Model.Email"
                       @(isLoggedIn ? "readonly" : "")/>
                <span asp-validation-for="Email" class="auth-validation-message"></span>
            </div>

            @if (Model?.CriteriaList != null && Model.CriteriaList.Any())
            {
                @foreach (var criteriaPair in Model.CriteriaList.Select((criteria, i) => new { criteria, i }))
                {
                    <div class="member-reg-form-group">
                        <label class="member-reg-criteria-group-label">@criteriaPair.criteria.Name</label>
                        <div class="member-reg-criteria-options-wrapper">
                            @if (criteriaPair.criteria.SubCriteria != null && criteriaPair.criteria.SubCriteria.Any())
                            {
                                @foreach (var subCriteria in criteriaPair.criteria.SubCriteria)
                                {
                                    bool isChecked = Model.SelectedCriteria != null
                                                     && Model.SelectedCriteria.Count > criteriaPair.i
                                                     && Model.SelectedCriteria[criteriaPair.i] == subCriteria.Id;
                                    <label class="member-reg-criteria-option-label @(isChecked ? "is-checked" : "")">
                                        <input type="radio" name="SelectedCriteria[@criteriaPair.i]" value="@subCriteria.Id" @(isChecked ? "checked" : "") class="mr-2"/>
                                        @subCriteria.Name
                                    </label>
                                }
                            }
                        </div>
                    </div>
                }
            }

            @* Verborgen velden voor model binding *@
            @for (int i = 0; i < Model?.CriteriaList?.Count; i++)
            {
                <input type="hidden" asp-for="CriteriaList[i].Name"/>
                @for (int j = 0; j < Model.CriteriaList[i].SubCriteria.Count; j++)
                {
                    <input type="hidden" asp-for="CriteriaList[i].SubCriteria[j].Id"/>
                    <input type="hidden" asp-for="CriteriaList[i].SubCriteria[j].Name"/>
                }
            }
            <input type="hidden" asp-for="@Model.Code">
            
            <button type="submit" class="auth-submit-button mt-6">Aanmelden</button>

            @if (!isLoggedIn)
            {
                <div>
                    <a id="existing-member"
                       asp-area="Identity"
                       asp-page="/Account/Login"
                       asp-route-returnUrl="@Url.Action("RegisterMember", "MemberRegister", new { code = Model.Code })">
                        Heeft u al een account binnen de organisatie?
                    </a>
                </div>
            }
        </form>
    </div>
</div>

<div id="confirmationModal" class="member-reg-modal-overlay hidden" aria-labelledby="confirmationModalLabel" aria-hidden="true">
    <div class="member-reg-modal-dialog">
        <div class="member-reg-modal-header">
            <h5 class="member-reg-modal-title" id="confirmationModalLabel">Bevestiging</h5>
        </div>
        <div class="member-reg-modal-body">
            <p>Weet u zeker dat u wilt meedoen?</p>
        </div>
        <div class="member-reg-modal-footer">
            <a href="@Url.Action("Index", "Home")" class="btn btn-danger">Ik wil niet meedoen</a>
            <input id="isConfirmed" type="hidden" asp-for="@Model.IsConfirmed"/>
            <button id="confirmParticipation" type="button" class="btn btn-accent">Ik wil meedoen</button>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/dist/clientapp/assets/memberRegister.js"></script>
}
