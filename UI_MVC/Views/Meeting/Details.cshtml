@model CitizenPanel.UI.MVC.Models.Panels.MeetingDetailViewModel

@using System.Globalization
@using Microsoft.AspNetCore.Mvc.TagHelpers
@{
    CultureInfo.CurrentCulture = new CultureInfo("nl-NL");
    CultureInfo.CurrentUICulture = new CultureInfo("nl-NL");
    ViewBag.Title = $"Meeting {Model.MeetingDate:dd MMMM yyyy}";
}

@section Styles {
    <link rel="stylesheet" href="~/dist/clientapp/assets/styles.css" asp-append-version="true" />
}

<div class="meeting-detail-page-container">
    <div class="meeting-detail-page-header">
        <div class="meeting-detail-back-link-wrapper">
            <a href="@Url.Action("Index", "Panel", new { id = Model.PanelId })" class="btn btn-secondary">
                <i class="fa-solid fa-arrow-left"></i> Terug naar @Model.PanelName
            </a>
            <h1 class="meeting-detail-title">Bijeenkomst: @Model.MeetingDate.ToString("dd MMMM yyyy")</h1>
        </div>
    </div>

    <div class="meeting-content-card">
        <div class="meeting-card-header">
            <h5>Aanbevelingen</h5>
            @if (User.IsInRole("Organization"))
            {
                <a asp-action="AddRecommendation"
                   asp-controller="Meeting"
                   asp-route-meetingId="@Model.MeetingId"
                   asp-route-panelId="@Model.PanelId"
                   class="btn btn-accent">
                    <i class="fa-solid fa-plus"></i> Aanbeveling Toevoegen
                </a>
            }
        </div>

        <div class="meeting-card-body">
            @if (Model.Recommendations != null && Model.Recommendations.Any())
            {
                <div class="meeting-recommendations-grid">
                    @foreach (var rec in Model.Recommendations)
                    {
                        <div class="meeting-recommendation-item">
                            <h5>@rec.Title</h5>
                            <p>@rec.Description</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="meeting-empty-state-text">Er zijn geen aanbevelingen voor deze meeting.</p>
            }
        </div>
    </div>

    <div class="meeting-content-card">
        <div class="meeting-card-header">
            <h5>Documenten</h5>
        </div>
        <div class="meeting-documents-card-body">
            @if (Model.DocumentNames.Any())
            {
                <ul class="meeting-documents-list">
                    @foreach (var docUrl in Model.DocumentNames)
                    {
                        <li class="meeting-document-item">
                            <div class="meeting-document-info">
                                <span class="badge bg-secondary">📄</span>
                                <a class="document-link" href="@docUrl" target="_blank">@System.IO.Path.GetFileName(docUrl)</a>
                            </div>
                            @if (User.IsInRole("Organization"))
                            {
                                <form asp-controller="Meeting" asp-action="RemoveDocument" method="post" class="mb-0"
                                      asp-route-meetingId="@Model.MeetingId"
                                      asp-route-fileUrl="@docUrl">
                                    <button type="submit" class="remove-document-button" title="Verwijder document">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            }
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="meeting-empty-state-text">Er zijn nog geen documenten toegevoegd voor deze meeting.</p>
            }

            @if (User.IsInRole("Organization"))
            {
                <form asp-controller="Meeting"
                      asp-action="Upload"
                      method="post"
                      asp-route-meetingId="@Model.MeetingId"
                      asp-route-panelId="@Model.PanelId"
                      enctype="multipart/form-data"
                      class="upload-document-form">
                    <input type="file" name="file" class="upload-file-input" />
                    <button type="submit" class="btn btn-accent ml-auto">
                        <i class="fa-solid fa-plus-circle"></i> Document toevoegen
                    </button>
                </form>

            }
        </div>
    </div>
</div>
