@model CitizenPanel.UI.MVC.Models.Panels.MeetingDetailViewModel

@using System.Globalization
@using Microsoft.AspNetCore.Mvc.TagHelpers
@{
    CultureInfo.CurrentCulture = new CultureInfo("nl-NL");
    CultureInfo.CurrentUICulture = new CultureInfo("nl-NL");
    ViewBag.Title = $"Meeting {Model.MeetingDate.ToString("dd MMMM yyyy")}";
}
@section Styles {
    <link rel="stylesheet" href="~/dist/clientapp/assets/styles.css" asp-append-version="true"/>
}

<div class="meeting-detail-page-container">
    <div class="meeting-detail-page-header">
        <div class="meeting-detail-back-link-wrapper">
            <a href="@Url.Action("Index", "Panel", new { id = Model.PanelId })" class="meeting-detail-back-link">
                <i class="fas fa-arrow-left"></i>Terug naar @Model.PanelName
            </a>
            <h1 class="meeting-detail-title">Bijeenkomst: @Model.MeetingDate.ToString("dd MMMM yyyy")</h1>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6"> 
        <div class="meeting-content-card">
            <div class="meeting-card-header">
                <h5>Aanbevelingen</h5>
                @if (User.IsInRole("Organization"))
                {
                    <a asp-action="AddRecommendation" asp-controller="Meeting"
                       asp-route-meetingId="@Model.MeetingId"
                       asp-route-panelId="@Model.PanelId"
                       class="btn btn-success">
                        <i class="fas fa-plus"></i> Aanbeveling Toevoegen
                    </a>
                }
            </div>

            <div class="meeting-card-body">
                @if (Model.Recommendations != null && Model.Recommendations.Any())
                {
                    <div class="meeting-recommendations-grid"> 
                        @foreach (var rec in Model.Recommendations)
                        {
                            <div class="meeting-recommendation-item">
                                <h5>@rec.Title</h5>
                                <p>@rec.Description</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="meeting-empty-state-text">Er zijn geen aanbevelingen voor deze meeting.</p>
                }
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0">Documenten</h5>
        </div>
        <div class="card-body">

            @if (Model.DocumentNames.Any())
            {
                <ul class="list-group mb-3">
                    @foreach (var doc in Model.DocumentNames)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-secondary">📄</span>
                                <a href="@doc" target="_blank">@System.IO.Path.GetFileName(doc)</a>
                            </div>
                            @if (User.IsInRole("Organization"))
                            {
                                <form asp-controller="Meeting" asp-action="RemoveDocument" method="post" class="mb-0" asp-route-meetingId="@Model.MeetingId" asp-route-fileName="@doc">
                                    <button type="submit" class="btn btn-sm btn-danger" title="Verwijder document" onclick="return confirm('Weet je zeker dat u dit document wilt verwijderen?');">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">Er zijn nog geen documenten toegevoegd voor deze meeting.</p>
            }

            @if (User.IsInRole("Organization"))
            {
                <form asp-controller="Meeting" asp-action="Upload" method="post" asp-route-meetingId="@Model.MeetingId" asp-route-panelId="@Model.PanelId" enctype="multipart/form-data">
                    <div class="mb-3">
                        <input type="file" name="file" class="form-control" />
                    </div>
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="bi bi-plus-circle me-2"></i>Document toevoegen
                    </button>
                </form>
            }
        </div>
    </div>
    
</div>
