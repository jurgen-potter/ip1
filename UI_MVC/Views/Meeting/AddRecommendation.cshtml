@model CitizenPanel.UI.MVC.Models.AddRecommendationViewModel

@{
ViewData["Title"] = "Aanbeveling Toevoegen";
}

<h1>Aanbeveling Toevoegen</h1>
<form asp-action="AddRecommendation" method="post">
    <input type="hidden" asp-for="MeetingId" />
    <input type="hidden" asp-for="PanelId" />

    <div class="mt-4 mb-2">
        <div class="form-group">
            <label asp-for="Title">Titel</label>
            <input asp-for="Title" class="form-control"/>
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
    </div>

    <div class="form-group">
        <label asp-for="Description">Beschrijving</label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="NeededVotes">Aantal nodige stemmen</label>
        <input type="number" asp-for="NeededVotes" class="form-control"></input>
        <span asp-validation-for="NeededVotes" class="text-danger"></span>
    </div>

    <div class="mt-4 mb-2">
        <button type="submit" class="btn btn-primary">Voeg Toe</button>
        <a asp-action="Details" asp-route-id="@Model.MeetingId" asp-route-panelId="@Model.PanelId" class="btn btn-secondary">Terug</a>
    </div>
</form>